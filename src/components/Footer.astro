---
// src/components/Footer.astro
import { SITE } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="footer-wrapper">
  <div class="container footer">
    <p class="footer-copy">&copy; {year} {SITE.author} &mdash; Built with Astro</p>
    <div class="footer-links">
      {SITE.social.github && (
        <a href={SITE.social.github} target="_blank" rel="noopener noreferrer">GitHub</a>
      )}
      {SITE.social.linkedin && (
        <a href={SITE.social.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      )}
      {SITE.social.twitter && (
        <a href={SITE.social.twitter} target="_blank" rel="noopener noreferrer">Twitter</a>
      )}
      <a href="/rss.xml">RSS</a>
    </div>
  </div>
</footer>

<style>
  .footer-wrapper {
    background: var(--bg);
    border-top: 1px solid var(--border);
    margin-top: 0;
  }

  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 2rem;
    flex-wrap: wrap;
    gap: 12px;
  }

  .footer-copy {
    font-size: 12px;
    color: var(--ink-4);
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
  }

  .footer-links a {
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-3);
    transition: color 0.15s;
  }
  .footer-links a:hover {
    color: var(--blue-600);
  }
</style>
