---
// src/components/Modal.astro
// Generic modal shell — content injected via JS
---

<!-- Backdrop -->
<div id="modal-backdrop" class="modal-backdrop" aria-hidden="true"></div>

<!-- Modal panel -->
<div id="modal-panel" class="modal-panel" role="dialog" aria-modal="true" aria-hidden="true">
  <!-- Drag handle (mobile) -->
  <div class="modal-handle"></div>

  <!-- Header -->
  <div class="modal-header">
    <div class="modal-header-left">
      <span id="modal-tag" class="modal-tag"></span>
      <span id="modal-status" class="modal-status" style="display:none"></span>
    </div>
    <button id="modal-close" class="modal-close-btn" aria-label="Close">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Cover image (optional) -->
  <div id="modal-cover" class="modal-cover" style="display:none">
    <img id="modal-cover-img" src="" alt="" loading="lazy" />
  </div>

  <!-- Body -->
  <div class="modal-body">
    <h2 id="modal-title" class="modal-title"></h2>
    <p id="modal-desc" class="modal-desc"></p>

    <!-- Metrics row (projects only) -->
    <div id="modal-metrics" class="modal-metrics" style="display:none"></div>

    <!-- Content sections -->
    <div id="modal-content" class="modal-content"></div>

    <!-- Tech stack / tags -->
    <div id="modal-stack" class="modal-stack" style="display:none">
      <p class="modal-section-label">Tech stack</p>
      <div id="modal-stack-pills" class="modal-stack-pills"></div>
    </div>

    <!-- Links -->
    <div id="modal-links" class="modal-links" style="display:none"></div>
  </div>
</div>

<style>
  /* Backdrop */
  .modal-backdrop {
    visibility: hidden;
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.5);
    backdrop-filter: blur(4px);
    z-index: 300;
    opacity: 0;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }
  .modal-backdrop.open {
    visibility: visible;
    opacity: 1;
  }

  /* Panel — mobile bottom sheet */
  .modal-panel {
    position: fixed;
    left: 0; right: 0; bottom: 0;
    max-height: 90vh;
    background: var(--white);
    border-radius: 20px 20px 0 0;
    overflow-y: auto;
    z-index: 400;
    transform: translateY(100%);
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
    box-shadow: 0 -8px 40px rgba(0,0,0,0.14);
  }
  .modal-panel.open {
    transform: translateY(0);
  }

  /* Desktop — centered modal */
  @media (min-width: 768px) {
    .modal-panel {
      top: 50%; left: 50%;
      right: auto; bottom: auto;
      width: 100%; max-width: 680px;
      max-height: 85vh;
      border-radius: 16px;
      transform: translate(-50%, -48%) scale(0.97);
      opacity: 0;
      transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s ease;
      box-shadow: 0 8px 48px rgba(0,0,0,0.18);
    }
    .modal-panel.open {
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
    }
  }

  /* Drag handle */
  .modal-handle {
    width: 40px; height: 4px;
    background: var(--border);
    border-radius: 2px;
    margin: 12px auto 0;
  }
  @media (min-width: 768px) { .modal-handle { display: none; } }

  /* Sticky header */
  .modal-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 16px 20px 12px;
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0;
    background: var(--white); z-index: 1;
  }
  .modal-header-left { display: flex; align-items: center; gap: 8px; }

  .modal-tag {
    font-family: var(--font-mono); font-size: 10px; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--blue-600); background: var(--blue-50);
    border: 1px solid var(--blue-200); padding: 3px 9px; border-radius: 4px;
  }
  .modal-status {
    font-family: var(--font-mono); font-size: 10px; font-weight: 500;
    padding: 3px 9px; border-radius: 4px;
  }
  .modal-status.live     { color: #059669; background: #ecfdf5; border: 1px solid #a7f3d0; }
  .modal-status.progress { color: #92400e; background: #fffbeb; border: 1px solid #fde68a; }

  .modal-close-btn {
    width: 32px; height: 32px; border-radius: 8px;
    border: 1px solid var(--border); background: var(--bg);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; color: var(--ink-3); font-family: inherit; flex-shrink: 0;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }
  .modal-close-btn:hover { border-color: var(--blue-200); background: var(--blue-50); color: var(--blue-600); }

  /* Cover */
  .modal-cover { width: 100%; height: 200px; overflow: hidden; border-bottom: 1px solid var(--border); }
  .modal-cover img { width: 100%; height: 100%; object-fit: cover; }
  @media (min-width: 768px) { .modal-cover { height: 240px; } }

  /* Body */
  .modal-body { padding: 20px; }

  .modal-title {
    font-family: var(--font-display); font-size: 1.375rem; font-weight: 700;
    letter-spacing: -0.02em; color: var(--ink); line-height: 1.25; margin-bottom: 10px;
  }
  .modal-desc { font-size: 0.875rem; color: var(--ink-3); line-height: 1.8; margin-bottom: 20px; }

  /* Metrics */
  .modal-metrics {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 10px; margin-bottom: 20px;
    padding-bottom: 20px; border-bottom: 1px solid var(--border);
  }
  .modal-metric-card { background: var(--bg); border-radius: 10px; padding: 12px; text-align: center; }
  .modal-metric-val { font-family: var(--font-display); font-size: 1.25rem; font-weight: 800; color: var(--blue-600); }
  .modal-metric-label { font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--ink-4); margin-top: 2px; }

  /* Content */
  .modal-content { margin-bottom: 20px; }
  .modal-section-label {
    font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-4);
    margin-bottom: 8px; margin-top: 18px;
  }
  .modal-section-label:first-child { margin-top: 0; }
  .modal-prose { font-size: 0.875rem; color: var(--ink-3); line-height: 1.8; margin-bottom: 4px; }

  .modal-outcome-list { display: flex; flex-direction: column; gap: 7px; margin-top: 4px; }
  .modal-outcome-item { display: flex; align-items: flex-start; gap: 10px; font-size: 0.875rem; color: var(--ink-3); line-height: 1.65; }
  .modal-outcome-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--blue-500); margin-top: 7px; flex-shrink: 0; }

  /* Stack */
  .modal-stack { margin-bottom: 20px; }
  .modal-stack-pills { display: flex; flex-wrap: wrap; gap: 6px; }
  .modal-pill { font-family: var(--font-mono); font-size: 0.7rem; color: var(--ink-3); background: var(--bg); border: 1px solid var(--border); padding: 3px 9px; border-radius: 20px; }

  /* Links */
  .modal-links { padding-top: 16px; border-top: 1px solid var(--border); display: flex; flex-wrap: wrap; gap: 8px; }
  .modal-link-btn {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.8rem; font-weight: 500; padding: 8px 16px;
    border-radius: 8px; border: 1px solid var(--border); color: var(--ink-2);
    text-decoration: none; transition: border-color 0.15s, background 0.15s, color 0.15s;
  }
  .modal-link-btn:hover { border-color: var(--blue-200); background: var(--blue-50); color: var(--blue-600); }
  .modal-link-btn.primary { background: var(--blue-600); color: #fff; border-color: var(--blue-600); }
  .modal-link-btn.primary:hover { background: var(--blue-700); border-color: var(--blue-700); color: #fff; }

  /* Cert-specific */
  .modal-cert-issuer { font-family: var(--font-mono); font-size: 0.75rem; color: var(--ink-4); margin-bottom: 4px; }
  .modal-cert-date { display: flex; gap: 16px; margin: 12px 0 16px; flex-wrap: wrap; }
  .modal-cert-date-item { display: flex; flex-direction: column; gap: 2px; }
  .modal-cert-date-label { font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-4); }
  .modal-cert-date-val { font-size: 0.875rem; font-weight: 500; color: var(--ink-2); }
</style>
