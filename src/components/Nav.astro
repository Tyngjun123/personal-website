---
// src/components/Nav.astro
import { SITE, NAV_LINKS } from '../config/site';

const currentPath = Astro.url.pathname;
---

<header class="nav-wrapper">
  <nav class="container nav">
    <a href="/" class="nav-logo">{SITE.name}</a>
    <ul class="nav-links">
      {NAV_LINKS.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['nav-link', { active: currentPath === link.href }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .nav-wrapper {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg);
    border-bottom: 0.5px solid var(--color-border);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .nav-logo {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
  }

  .nav-link {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    transition: color 0.15s;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-text);
  }
</style>
