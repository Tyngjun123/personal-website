---
// src/components/SEO.astro
// Drop this into any layout — handles ALL SEO tags automatically

import { SITE } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  type?: 'website' | 'article' | 'profile';
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    tags?: string[];
    section?: string;
  };
  noindex?: boolean;
  keywords?: string[];
  jsonLd?: object; // Pass custom JSON-LD schema
}

const {
  title,
  description = SITE.description,
  image = SITE.ogImage,
  canonicalURL = new URL(Astro.url.pathname, SITE.url).href,
  type = 'website',
  article,
  noindex = false,
  keywords = [],
  jsonLd,
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE.name}` : SITE.title;
const ogImage = image.startsWith('http') ? image : new URL(image, SITE.url).href;

// Default JSON-LD: Person schema for personal site
const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.author,
  url: SITE.url,
  jobTitle: SITE.authorRole,
  description: SITE.authorBio,
  sameAs: [
    SITE.social.github,
    SITE.social.linkedin,
    SITE.social.twitter,
  ].filter(Boolean),
};

// Article JSON-LD
const articleJsonLd = article ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: ogImage,
  author: {
    '@type': 'Person',
    name: SITE.author,
    url: SITE.url,
  },
  publisher: {
    '@type': 'Person',
    name: SITE.author,
    url: SITE.url,
  },
  datePublished: article.publishedTime,
  dateModified: article.modifiedTime ?? article.publishedTime,
  keywords: article.tags?.join(', '),
  articleSection: article.section,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL,
  },
} : null;

const activeJsonLd = jsonLd ?? articleJsonLd ?? defaultJsonLd;
---

<!-- Primary Meta -->
<title>{pageTitle}</title>
<meta name="description" content={description} />
{keywords.length > 0 && (
  <meta name="keywords" content={keywords.join(', ')} />
)}
<meta name="author" content={SITE.author} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<meta name="theme-color" content={SITE.themeColor} />

<!-- Canonical URL — prevents duplicate content penalty -->
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph (Facebook, LinkedIn, WhatsApp previews) -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:locale" content={SITE.locale} />

<!-- Article-specific OG tags -->
{article && (
  <>
    <meta property="article:published_time" content={article.publishedTime} />
    {article.modifiedTime && (
      <meta property="article:modified_time" content={article.modifiedTime} />
    )}
    <meta property="article:author" content={SITE.author} />
    {article.section && (
      <meta property="article:section" content={article.section} />
    )}
    {article.tags?.map(tag => (
      <meta property="article:tag" content={tag} />
    ))}
  </>
)}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
{SITE.twitterHandle && (
  <meta name="twitter:creator" content={SITE.twitterHandle} />
)}

<!-- RSS Feed discovery -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${SITE.name} — Articles RSS Feed`}
  href="/rss.xml"
/>

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(activeJsonLd)} />
