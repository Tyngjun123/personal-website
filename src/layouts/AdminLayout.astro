---
// src/layouts/AdminLayout.astro
interface Props {
  title: string;
}
const { title } = Astro.props;
const path = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — Admin</title>
  </head>
  <body>
    <div class="admin-shell">
      <aside class="sidebar">
        <div class="sidebar-logo">
          <a href="/" class="logo-link">TJ</a>
          <span class="logo-badge">Admin</span>
        </div>
        <nav class="sidebar-nav">
          <a href="/admin" class:list={['nav-item', { active: path === '/admin' || path === '/admin/' }]}>
            <span class="nav-icon">▦</span> Dashboard
          </a>
          <a href="/admin/seo" class:list={['nav-item', { active: path.startsWith('/admin/seo') }]}>
            <span class="nav-icon">◎</span> SEO Monitor
          </a>
          <a href="/admin/upload" class:list={['nav-item', { active: path.startsWith('/admin/upload') }]}>
            <span class="nav-icon">↑</span> Upload Files
          </a>

          <div class="nav-section">CMS</div>

          <a href="/admin/cms/home" class:list={['nav-item', { active: path.startsWith('/admin/cms/home') }]}>
            <span class="nav-icon">⌂</span> Home & Social
          </a>
          <a href="/admin/cms/articles" class:list={['nav-item', { active: path.startsWith('/admin/cms/articles') }]}>
            <span class="nav-icon">✎</span> Articles
          </a>
          <a href="/admin/cms/projects" class:list={['nav-item', { active: path.startsWith('/admin/cms/projects') }]}>
            <span class="nav-icon">◈</span> Projects
          </a>
          <a href="/admin/cms/certificates" class:list={['nav-item', { active: path.startsWith('/admin/cms/certificates') }]}>
            <span class="nav-icon">✦</span> Certificates
          </a>
        </nav>
        <div class="sidebar-footer">
          <a href="/admin/logout" class="logout-btn">Sign out</a>
        </div>
      </aside>

      <main class="admin-main">
        <header class="admin-topbar">
          <h1 class="page-title">{title}</h1>
        </header>
        <div class="admin-content">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body { height: 100%; }

  body {
    font-family: 'DM Sans', system-ui, sans-serif;
    background: #0f0f0f;
    color: #e5e7eb;
    font-size: 14px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  a { color: inherit; text-decoration: none; }

  .admin-shell {
    display: grid;
    grid-template-columns: 220px 1fr;
    min-height: 100vh;
  }

  /* Sidebar */
  .sidebar {
    background: #0a0a0a;
    border-right: 1px solid #1f1f1f;
    display: flex;
    flex-direction: column;
    padding: 1.5rem 1rem;
    position: sticky;
    top: 0;
    height: 100vh;
  }

  .sidebar-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 0.5rem;
    margin-bottom: 2rem;
  }

  .logo-link {
    font-size: 1.1rem;
    font-weight: 600;
    color: #f9fafb;
    letter-spacing: -0.02em;
  }

  .logo-badge {
    font-size: 0.65rem;
    padding: 2px 7px;
    background: #1f1f1f;
    border: 1px solid #2d2d2d;
    border-radius: 4px;
    color: #6b7280;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0.55rem 0.75rem;
    border-radius: 6px;
    color: #6b7280;
    font-size: 0.85rem;
    transition: background 0.15s, color 0.15s;
  }

  .nav-item:hover { background: #1a1a1a; color: #d1d5db; }
  .nav-item.active { background: #1a1a1a; color: #f9fafb; }

  .nav-icon { font-size: 0.75rem; width: 16px; text-align: center; }

  .nav-section {
    font-size: 0.65rem;
    color: #374151;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 1rem 0.75rem 0.25rem;
  }

  .sidebar-footer {
    padding-top: 1rem;
    border-top: 1px solid #1f1f1f;
  }

  .logout-btn {
    display: block;
    padding: 0.5rem 0.75rem;
    font-size: 0.8rem;
    color: #6b7280;
    border-radius: 6px;
    transition: background 0.15s, color 0.15s;
  }

  .logout-btn:hover { background: #1a1a1a; color: #f87171; }

  /* Main */
  .admin-main {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    overflow: hidden;
  }

  .admin-topbar {
    padding: 1.25rem 2rem;
    border-bottom: 1px solid #1f1f1f;
    background: #0f0f0f;
  }

  .page-title {
    font-size: 1rem;
    font-weight: 500;
    color: #f9fafb;
    letter-spacing: -0.01em;
  }

  .admin-content {
    padding: 2rem;
    flex: 1;
  }
</style>
