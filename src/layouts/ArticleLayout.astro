---
// src/layouts/ArticleLayout.astro
// Layout for individual article pages

import BaseLayout from './BaseLayout.astro';
import { SITE } from '../config/site';

interface Props {
  title: string;
  description: string;
  publishedDate: string;
  modifiedDate?: string;
  category: string;
  tags: string[];
  cover?: string;
  readTime?: string;
  toc?: boolean;
  slug: string;
  keywords?: string[];
}

const {
  title,
  description,
  publishedDate,
  modifiedDate,
  category,
  tags,
  cover,
  readTime = '5 min',
  toc = false,
  slug,
  keywords = [],
} = Astro.props;

const canonicalURL = `${SITE.url}/articles/${slug}`;
const ogImage = cover ?? SITE.ogImage;

const formattedDate = new Date(publishedDate).toLocaleDateString('en-MY', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={title}
  description={description}
  image={ogImage}
  type="article"
  canonicalURL={canonicalURL}
  keywords={[...tags, ...keywords, category]}
  article={{
    publishedTime: publishedDate,
    modifiedTime: modifiedDate,
    author: SITE.author,
    tags,
    section: category,
  }}
>
  <article class="article-page">

    <!-- Hero -->
    <header class="art-header">
      <div class="container">
        <a href="/articles" class="back-link">← All articles</a>
        <div class="art-meta">
          <span class="art-cat">{category}</span>
          <span class="art-dot"></span>
          <time datetime={publishedDate}>{formattedDate}</time>
          <span class="art-dot"></span>
          <span>{readTime} read</span>
        </div>
        <h1 class="art-title">{title}</h1>
        <p class="art-excerpt">{description}</p>
        <div class="art-author">
          <div class="author-avatar">{SITE.author.slice(0,2).toUpperCase()}</div>
          <div>
            <div class="author-name">{SITE.author}</div>
            <div class="author-role">{SITE.authorRole}</div>
          </div>
        </div>
      </div>
    </header>

    <!-- Cover image -->
    {cover && (
      <div class="art-cover">
        <img src={cover} alt={title} width="1200" height="630" loading="eager" />
      </div>
    )}

    <!-- Body: content + sidebar -->
    <div class="art-body container">
      <div class="art-content">
        <!-- TOC injected by JS from headings if toc=true -->
        {toc && <div id="toc-container" class="toc-block"></div>}

        <div class="prose">
          <slot />
        </div>

        <!-- Tags -->
        <div class="art-tags">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>

        <!-- Share -->
        <div class="share-row">
          <span class="share-label">Share</span>
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(canonicalURL)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="share-btn"
          >Twitter / X</a>
          <a
            href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalURL)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="share-btn"
          >LinkedIn</a>
          <button class="share-btn" id="copy-link">Copy link</button>
        </div>
      </div>

      <aside class="art-sidebar">
        <!-- Reading progress -->
        <div class="sidebar-block">
          <div class="sidebar-label">Reading progress</div>
          <div class="progress-track">
            <div class="progress-fill" id="reading-progress"></div>
          </div>
          <div class="progress-pct" id="progress-pct">0%</div>
        </div>

        <!-- Tags -->
        <div class="sidebar-block">
          <div class="sidebar-label">Tags</div>
          <div class="tag-cloud">
            {tags.map(tag => <span class="tag-item">{tag}</span>)}
          </div>
        </div>

        <!-- Author -->
        <div class="sidebar-block">
          <div class="sidebar-label">About the author</div>
          <div class="author-card">
            <div class="author-card-top">
              <div class="author-card-avatar">{SITE.author.slice(0,2).toUpperCase()}</div>
              <div>
                <div class="author-card-name">{SITE.author}</div>
                <div class="author-card-role">{SITE.authorRole}</div>
              </div>
            </div>
            <p class="author-card-bio">{SITE.authorBio}</p>
          </div>
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>

<script>
  // Reading progress bar
  const progressFill = document.getElementById('reading-progress');
  const progressPct = document.getElementById('progress-pct');
  window.addEventListener('scroll', () => {
    const doc = document.documentElement;
    const scrolled = doc.scrollTop / (doc.scrollHeight - doc.clientHeight);
    const pct = Math.round(scrolled * 100);
    if (progressFill) progressFill.style.width = `${pct}%`;
    if (progressPct) progressPct.textContent = `${pct}%`;
  });

  // Auto-generate TOC from headings
  const tocContainer = document.getElementById('toc-container');
  if (tocContainer) {
    const headings = document.querySelectorAll('.prose h2');
    if (headings.length > 0) {
      tocContainer.innerHTML = `
        <div class="toc-label">In this article</div>
        <nav class="toc-list">
          ${Array.from(headings).map((h, i) => {
            const id = h.id || `section-${i}`;
            h.id = id;
            return `<a href="#${id}" class="toc-item">
              <span class="toc-num">0${i + 1}</span>
              ${h.textContent}
            </a>`;
          }).join('')}
        </nav>
      `;
    }
  }

  // Copy link button
  document.getElementById('copy-link')?.addEventListener('click', () => {
    navigator.clipboard.writeText(window.location.href);
  });
</script>

<style>
  .article-page { padding-bottom: 5rem; }

  /* Hero header */
  .art-header {
    background: linear-gradient(180deg, var(--bg) 0%, var(--white) 100%);
    padding: 48px 0 40px;
    border-bottom: 1px solid var(--border);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-4);
    margin-bottom: 20px;
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--blue-600); }

  .art-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-3);
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .art-cat {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 9px;
    border-radius: 4px;
    background: var(--blue-50);
    color: var(--blue-700);
    border: 1px solid var(--blue-200);
  }
  .art-dot {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--ink-5);
  }

  .art-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin-bottom: 16px;
    max-width: 700px;
    line-height: 1.15;
  }
  .art-excerpt {
    font-size: 15px;
    color: var(--ink-3);
    line-height: 1.75;
    max-width: 620px;
    margin-bottom: 24px;
  }

  .art-author { display: flex; align-items: center; gap: 10px; }
  .author-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: var(--blue-50);
    border: 1px solid var(--blue-200);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: var(--blue-600);
    flex-shrink: 0;
  }
  .author-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
  }
  .author-role {
    font-size: 12px;
    color: var(--ink-4);
    margin-top: 1px;
  }

  .art-cover {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .art-cover img { width: 100%; max-height: 420px; object-fit: cover; }

  /* Body layout */
  .art-body {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 0;
    align-items: start;
    padding-top: 40px;
  }

  .art-content {
    padding-right: 48px;
    border-right: 1px solid var(--border);
    min-width: 0;
  }

  /* TOC */
  :global(.toc-block) {
    background: var(--bg);
    border-radius: var(--radius);
    border: 1px solid var(--border-blue);
    padding: 16px 18px;
    margin-bottom: 32px;
  }
  :global(.toc-label) {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-4);
    margin-bottom: 12px;
  }
  :global(.toc-list) { display: flex; flex-direction: column; }
  :global(.toc-item) {
    display: flex;
    gap: 10px;
    font-size: 13px;
    color: var(--ink-3);
    padding: 7px 0;
    border-bottom: 1px solid var(--border);
    transition: color 0.15s;
  }
  :global(.toc-item:last-child) { border-bottom: none; padding-bottom: 0; }
  :global(.toc-item:hover) { color: var(--blue-600); }
  :global(.toc-num) {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-4);
    width: 18px;
    flex-shrink: 0;
    padding-top: 2px;
  }

  /* Prose */
  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    margin: 2.25rem 0 0.75rem;
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    margin: 1.75rem 0 0.5rem;
    color: var(--ink);
  }
  .prose :global(p) {
    font-size: 0.9375rem;
    color: var(--ink-2);
    line-height: 1.85;
    margin-bottom: 1rem;
  }
  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
    color: var(--ink-2);
    font-size: 0.9375rem;
    line-height: 1.8;
  }
  .prose :global(li) { margin-bottom: 4px; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--blue-500);
    padding: 12px 16px;
    margin: 1.5rem 0;
    background: var(--blue-50);
    border-radius: 0 var(--radius) var(--radius) 0;
    font-style: italic;
    color: var(--ink-2);
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }
  .prose :global(a) {
    color: var(--blue-600);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.15s;
  }
  .prose :global(a:hover) { color: var(--blue-700); }

  /* Tags */
  .art-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 3px 10px;
    border-radius: 20px;
  }

  /* Share */
  .share-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    flex-wrap: wrap;
  }
  .share-label {
    font-size: 12px;
    color: var(--ink-4);
    font-family: var(--font-mono);
  }
  .share-btn {
    font-size: 12px;
    padding: 5px 13px;
    border: 1px solid var(--border);
    border-radius: 20px;
    color: var(--ink-2);
    background: transparent;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
    font-family: var(--font-body);
  }
  .share-btn:hover {
    border-color: var(--blue-200);
    color: var(--blue-600);
  }

  /* Sidebar */
  .art-sidebar {
    padding-left: 28px;
    position: sticky;
    top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .sidebar-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-4);
    margin-bottom: 10px;
  }
  .progress-track {
    width: 100%;
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    margin-bottom: 4px;
    overflow: hidden;
  }
  .progress-fill {
    height: 4px;
    background: linear-gradient(90deg, var(--blue-500), #6366f1);
    border-radius: 2px;
    width: 0%;
    transition: width 0.1s;
  }
  .progress-pct {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-4);
  }

  .tag-cloud { display: flex; flex-wrap: wrap; gap: 5px; }
  .tag-item {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 3px 9px;
    border-radius: 20px;
  }

  .author-card {
    border: 1px solid var(--border-blue);
    border-radius: var(--radius);
    padding: 14px;
    background: var(--blue-50);
  }
  .author-card-top { display: flex; gap: 10px; align-items: center; margin-bottom: 10px; }
  .author-card-avatar {
    width: 34px; height: 34px;
    border-radius: 50%;
    background: var(--white);
    border: 1px solid var(--blue-200);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 700;
    color: var(--blue-600);
    flex-shrink: 0;
  }
  .author-card-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
  }
  .author-card-role {
    font-size: 11px;
    color: var(--ink-4);
  }
  .author-card-bio {
    font-size: 12px;
    color: var(--ink-2);
    line-height: 1.65;
  }

  @media (max-width: 768px) {
    .art-body { grid-template-columns: 1fr; }
    .art-content { padding-right: 0; border-right: none; }
    .art-sidebar {
      position: static;
      padding-left: 0;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }
  }
</style>
