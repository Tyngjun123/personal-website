---
export const prerender = false;
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { isConfigured, getFile, saveFile, parseMdx, buildMdx, slugify } from '../../../../lib/github';

const configured = isConfigured();
const ARTICLES_PATH = 'src/content/articles';

const slugParam = Astro.url.searchParams.get('slug') ?? '';
const isEdit = !!slugParam;

let fields: Record<string, any> = {
  title: '', description: '', publishedDate: new Date().toISOString().slice(0, 10),
  category: 'Automation', tags: '', cover: '', readTime: '5 min',
  toc: false, featured: false, draft: false, keywords: '',
};
let body = '';
let sha = '';
let errorMsg = '';
let successMsg = '';

// Load existing article for edit
if (isEdit && configured) {
  try {
    const file = await getFile(`${ARTICLES_PATH}/${slugParam}.mdx`);
    sha = file.sha;
    const { data, body: b } = parseMdx(file.content);
    fields = {
      ...fields,
      ...data,
      tags:     Array.isArray(data.tags)     ? data.tags.join(', ')     : (data.tags ?? ''),
      keywords: Array.isArray(data.keywords) ? data.keywords.join(', ') : (data.keywords ?? ''),
    };
    body = b;
  } catch (e: any) {
    errorMsg = `Could not load article: ${e.message}`;
  }
}

// Handle save
if (Astro.request.method === 'POST' && configured) {
  try {
    const form = await Astro.request.formData();
    const g = (k: string) => form.get(k)?.toString().trim() ?? '';

    const title = g('title');
    const slug = isEdit ? slugParam : slugify(title);

    const frontmatter: Record<string, any> = {
      title,
      description:   g('description'),
      publishedDate: g('publishedDate'),
      category:      g('category'),
      tags:          g('tags').split(',').map((t: string) => t.trim()).filter(Boolean),
      cover:         g('cover') || undefined,
      readTime:      g('readTime') || undefined,
      toc:           form.get('toc') === 'on',
      featured:      form.get('featured') === 'on',
      draft:         form.get('draft') === 'on',
      keywords:      g('keywords') ? g('keywords').split(',').map((k: string) => k.trim()).filter(Boolean) : undefined,
    };

    const content = buildMdx(frontmatter, g('body'));
    const filePath = `${ARTICLES_PATH}/${slug}.mdx`;

    await saveFile(filePath, content, isEdit ? sha : undefined, `CMS: ${isEdit ? 'update' : 'create'} article ${slug}`);
    successMsg = `Article "${title}" ${isEdit ? 'updated' : 'created'}. Vercel rebuilding…`;

    if (!isEdit) {
      return Astro.redirect(`/admin/cms/articles/edit?slug=${slug}&saved=1`);
    }
    // Refresh sha after save
    try { const f = await getFile(filePath); sha = f.sha; } catch {}
  } catch (e: any) {
    errorMsg = e.message;
  }
}

if (Astro.url.searchParams.get('saved')) successMsg = 'Article saved. Vercel rebuilding…';

const title = isEdit ? `Edit: ${fields.title || slugParam}` : 'New article';
---

<AdminLayout title={title}>
  <div class="edit-header">
    <a href="/admin/cms/articles" class="back-link">← All articles</a>
    {isEdit && <a href={`/articles/${slugParam}`} target="_blank" class="view-link">View live →</a>}
  </div>

  {!configured && <div class="notice">GitHub not configured.</div>}
  {successMsg && <div class="alert alert-ok">{successMsg}</div>}
  {errorMsg   && <div class="alert alert-err">{errorMsg}</div>}

  <form method="POST" class="edit-form">
    <div class="edit-grid">
      <!-- Left: body -->
      <div class="edit-main">
        <div class="field">
          <label>Title</label>
          <input name="title" value={fields.title} placeholder="Article title" required />
        </div>
        <div class="field">
          <label>Description <span class="hint">120–160 chars</span></label>
          <textarea name="description" rows="3">{fields.description}</textarea>
        </div>
        <div class="field">
          <label>Body <span class="hint">(Markdown / MDX)</span></label>
          <textarea name="body" rows="24" class="body-editor">{body}</textarea>
        </div>
      </div>

      <!-- Right: meta -->
      <aside class="edit-sidebar">
        <div class="sidebar-card">
          <div class="field">
            <label>Published date</label>
            <input name="publishedDate" value={fields.publishedDate} placeholder="2026-03-22" />
          </div>
          <div class="field">
            <label>Category</label>
            <input name="category" value={fields.category} placeholder="Automation" />
          </div>
          <div class="field">
            <label>Tags <span class="hint">comma separated</span></label>
            <input name="tags" value={fields.tags} placeholder="n8n, API, Workflow" />
          </div>
          <div class="field">
            <label>Keywords <span class="hint">comma separated</span></label>
            <input name="keywords" value={fields.keywords} placeholder="n8n automation Malaysia" />
          </div>
          <div class="field">
            <label>Cover image URL</label>
            <input name="cover" value={fields.cover ?? ''} placeholder="/images/articles/my-cover.jpg" />
          </div>
          <div class="field">
            <label>Read time</label>
            <input name="readTime" value={fields.readTime ?? '5 min'} placeholder="5 min" />
          </div>
          <div class="checks">
            <label class="check-label">
              <input type="checkbox" name="toc"      checked={fields.toc}      /> Table of contents
            </label>
            <label class="check-label">
              <input type="checkbox" name="featured" checked={fields.featured} /> Featured
            </label>
            <label class="check-label">
              <input type="checkbox" name="draft"    checked={fields.draft}    /> Draft
            </label>
          </div>
        </div>

        <button type="submit" class="btn-save" disabled={!configured}>
          {isEdit ? 'Save changes' : 'Publish article'}
        </button>
      </aside>
    </div>
  </form>
</AdminLayout>

<style>
  .edit-header { display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem; }
  .back-link,.view-link { font-size:.8rem;color:#4b5563;transition:color .15s; }
  .back-link:hover,.view-link:hover { color:#9ca3af; }

  .notice { background:#1a1200;border:1px solid #3d2e00;color:#fbbf24;padding:.875rem 1rem;border-radius:8px;margin-bottom:1.25rem;font-size:.82rem; }
  .alert { padding:.75rem 1rem;border-radius:6px;font-size:.82rem;margin-bottom:1.25rem; }
  .alert-ok  { background:#0a1f15;border:1px solid #064e3b;color:#34d399; }
  .alert-err { background:#1f0a0a;border:1px solid #7f1d1d;color:#f87171; }

  .edit-form { flex:1; }
  .edit-grid { display:grid;grid-template-columns:1fr 280px;gap:1.5rem;align-items:start; }

  .edit-main { display:flex;flex-direction:column;gap:1rem; }

  .field { display:flex;flex-direction:column;gap:5px; }
  label { font-size:.75rem;color:#6b7280; }
  .hint { color:#374151;font-size:.7rem; }

  input,textarea {
    background:#111;border:1px solid #2d2d2d;border-radius:6px;
    color:#e5e7eb;font-family:inherit;font-size:.85rem;
    padding:.5rem .75rem;outline:none;transition:border-color .15s;width:100%;
  }
  textarea { resize:vertical;line-height:1.65; }
  .body-editor { font-family:'Fira Code','Cascadia Code',monospace;font-size:.82rem;line-height:1.7; }
  input:focus,textarea:focus { border-color:#4b5563; }

  .edit-sidebar { display:flex;flex-direction:column;gap:1rem;position:sticky;top:5rem; }

  .sidebar-card {
    background:#1a1a1a;border:1px solid #2d2d2d;border-radius:8px;
    padding:1.25rem;display:flex;flex-direction:column;gap:.875rem;
  }

  .checks { display:flex;flex-direction:column;gap:6px; }
  .check-label { display:flex;align-items:center;gap:8px;font-size:.8rem;color:#6b7280;cursor:pointer; }
  .check-label input { width:auto;padding:0; }

  .btn-save {
    background:#f9fafb;border:none;border-radius:6px;color:#0f0f0f;
    cursor:pointer;font-family:inherit;font-size:.85rem;font-weight:500;
    padding:.6rem;transition:opacity .15s;width:100%;
  }
  .btn-save:hover:not(:disabled) { opacity:.85; }
  .btn-save:disabled { opacity:.3;cursor:not-allowed; }

  @media (max-width:800px) {
    .edit-grid { grid-template-columns:1fr; }
    .edit-sidebar { position:static; }
  }
</style>
