---
export const prerender = false;
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { isConfigured, listDir, getFile, deleteFile } from '../../../../lib/github';

const configured = isConfigured();
const CERTS_PATH = 'src/content/certificates';
let certs: any[] = [];
let errorMsg = '';
let successMsg = '';

if (Astro.request.method === 'POST' && configured) {
  const form = await Astro.request.formData();
  if (form.get('_action') === 'delete') {
    const id = form.get('id')?.toString() ?? '';
    try {
      const file = await getFile(`${CERTS_PATH}/${id}.json`);
      await deleteFile(`${CERTS_PATH}/${id}.json`, file.sha, `CMS: delete certificate ${id}`);
      successMsg = `Certificate "${id}" deleted. Rebuilding…`;
    } catch (e: any) { errorMsg = e.message; }
  }
}

if (configured) {
  try {
    const files = (await listDir(CERTS_PATH)).filter(f => f.name.endsWith('.json'));
    certs = await Promise.all(files.map(async f => {
      try {
        const file = await getFile(f.path);
        const data = JSON.parse(file.content);
        return { id: f.name.replace('.json', ''), name: data.name ?? f.name, issuer: data.issuer ?? '', issuedDate: data.issuedDate ?? '', category: data.category ?? '' };
      } catch { return { id: f.name.replace('.json', ''), name: f.name, issuer: '', issuedDate: '', category: '' }; }
    }));
    certs.sort((a, b) => b.issuedDate.localeCompare(a.issuedDate));
  } catch (e: any) { errorMsg = e.message; }
}
---

<AdminLayout title="Certificates">
  {!configured && <div class="notice">GitHub not configured. Add <code>GITHUB_TOKEN</code>, <code>GITHUB_OWNER</code>, <code>GITHUB_REPO</code>.</div>}
  {successMsg && <div class="alert alert-ok">{successMsg}</div>}
  {errorMsg   && <div class="alert alert-err">{errorMsg}</div>}

  <div class="list-header">
    <span class="list-count">{certs.length} certificate{certs.length !== 1 ? 's' : ''}</span>
    <a href="/admin/cms/certificates/edit" class="btn-new">+ New certificate</a>
  </div>

  <ul class="item-list">
    {certs.map(c => (
      <li class="item">
        <div class="item-info">
          <div class="item-title">{c.name}</div>
          <div class="item-meta">{c.issuer}{c.issuedDate ? ` · ${c.issuedDate}` : ''}{c.category ? ` · ${c.category}` : ''}</div>
        </div>
        <div class="item-actions">
          <a href={`/admin/cms/certificates/edit?id=${c.id}`} class="btn-action">Edit</a>
          <form method="POST" onsubmit="return confirm('Delete this certificate?')">
            <input type="hidden" name="_action" value="delete" />
            <input type="hidden" name="id" value={c.id} />
            <button type="submit" class="btn-action btn-delete">Delete</button>
          </form>
        </div>
      </li>
    ))}
  </ul>
</AdminLayout>

<style>
  .notice{background:#1a1200;border:1px solid #3d2e00;color:#fbbf24;padding:1rem;border-radius:8px;margin-bottom:1.5rem;font-size:.82rem;}
  code{background:#2d2200;padding:1px 5px;border-radius:3px;font-family:monospace;font-size:.82em;}
  .alert{padding:.75rem 1rem;border-radius:6px;font-size:.82rem;margin-bottom:1.25rem;}
  .alert-ok{background:#0a1f15;border:1px solid #064e3b;color:#34d399;}
  .alert-err{background:#1f0a0a;border:1px solid #7f1d1d;color:#f87171;}
  .list-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;}
  .list-count{font-size:.82rem;color:#4b5563;}
  .btn-new{background:#f9fafb;border-radius:6px;color:#0f0f0f;font-size:.8rem;font-weight:500;padding:.45rem 1rem;}
  .item-list{list-style:none;display:flex;flex-direction:column;}
  .item{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:.875rem 0;border-bottom:1px solid #1f1f1f;}
  .item-info{flex:1;min-width:0;}
  .item-title{font-size:.875rem;color:#d1d5db;margin-bottom:3px;}
  .item-meta{font-size:.75rem;color:#4b5563;}
  .item-actions{display:flex;gap:8px;flex-shrink:0;}
  .btn-action{font-size:.75rem;padding:.35rem .75rem;border-radius:5px;background:#1f1f1f;border:1px solid #2d2d2d;color:#9ca3af;cursor:pointer;font-family:inherit;transition:background .15s;text-decoration:none;display:inline-block;}
  .btn-action:hover{background:#2d2d2d;}
  .btn-delete:hover{background:#2d1515;border-color:#7f1d1d;color:#f87171;}
</style>
