---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { isConfigured, getFile, saveFile } from '../../../lib/github';

const configured = isConfigured();
let successMsg = '';
let errorMsg = '';
let settings: any = {};

const SETTINGS_PATH = 'src/data/cms-settings.json';

if (configured) {
  try {
    const file = await getFile(SETTINGS_PATH);
    settings = JSON.parse(file.content);
  } catch (e: any) {
    errorMsg = `Could not load settings: ${e.message}`;
  }
}

if (Astro.request.method === 'POST' && configured) {
  try {
    const form = await Astro.request.formData();
    const g = (k: string) => form.get(k)?.toString().trim() ?? '';

    const file = await getFile(SETTINGS_PATH);
    const current = JSON.parse(file.content);

    // Parse work experience array
    const workCount = parseInt(g('work_count') || '0', 10);
    const workExperience = [];
    for (let i = 0; i < workCount; i++) {
      const company = g(`work_${i}_company`);
      if (!company) continue;
      workExperience.push({
        company,
        role: g(`work_${i}_role`),
        period: g(`work_${i}_period`),
        current: form.get(`work_${i}_current`) === 'on',
        description: g(`work_${i}_description`),
        tags: g(`work_${i}_tags`).split(',').map((t: string) => t.trim()).filter(Boolean),
      });
    }

    // Parse education array
    const eduCount = parseInt(g('edu_count') || '0', 10);
    const education = [];
    for (let i = 0; i < eduCount; i++) {
      const school = g(`edu_${i}_school`);
      if (!school) continue;
      education.push({
        school,
        degree: g(`edu_${i}_degree`),
        period: g(`edu_${i}_period`),
        tags: g(`edu_${i}_tags`).split(',').map((t: string) => t.trim()).filter(Boolean),
      });
    }

    const updated = {
      ...current,
      name:        g('name'),
      title:       g('title'),
      description: g('description'),
      url:         g('url'),
      author:      g('author'),
      authorRole:  g('authorRole'),
      authorBio:   g('authorBio'),
      location:    g('location'),
      email:       g('email'),
      twitterHandle: g('twitterHandle'),
      social: {
        github:    g('github'),
        linkedin:  g('linkedin'),
        twitter:   g('twitter'),
        facebook:  g('facebook'),
        instagram: g('instagram'),
        tiktok:    g('tiktok'),
        youtube:   g('youtube'),
      },
      workExperience,
      education,
    };

    await saveFile(SETTINGS_PATH, JSON.stringify(updated, null, 2), file.sha, 'CMS: update site settings');
    settings = updated;
    successMsg = 'Settings saved. Vercel will rebuild in ~1–2 minutes.';
  } catch (e: any) {
    errorMsg = e.message;
  }
}

const s = settings;
const workItems: any[] = s.workExperience ?? [];
const eduItems: any[] = s.education ?? [];
---

<AdminLayout title="Home & Social Settings">
  {!configured && (
    <div class="notice">
      <strong>GitHub not configured.</strong> Add <code>GITHUB_TOKEN</code>, <code>GITHUB_OWNER</code>, and <code>GITHUB_REPO</code> to your Vercel environment variables, then redeploy.
    </div>
  )}

  {successMsg && <div class="alert alert-ok">{successMsg}</div>}
  {errorMsg   && <div class="alert alert-err">{errorMsg}</div>}

  <form method="POST" class="cms-form">

    <!-- ── Homepage basics ── -->
    <section class="form-section">
      <h2 class="form-section-title">Homepage content</h2>
      <div class="fields">
        <div class="field">
          <label>Display name</label>
          <input name="name" value={s.name ?? ''} placeholder="TJ" />
        </div>
        <div class="field">
          <label>Page title <span class="hint">(shown in browser tab + Google)</span></label>
          <input name="title" value={s.title ?? ''} placeholder="TJ — Product Owner & Automation Engineer" />
        </div>
        <div class="field">
          <label>Meta description <span class="hint">(120–160 chars ideal)</span></label>
          <textarea name="description" rows="3">{s.description ?? ''}</textarea>
        </div>
        <div class="field">
          <label>Author name</label>
          <input name="author" value={s.author ?? ''} />
        </div>
        <div class="field">
          <label>Role / tagline</label>
          <input name="authorRole" value={s.authorRole ?? ''} placeholder="Product Owner · Automation Engineer" />
        </div>
        <div class="field">
          <label>Bio</label>
          <textarea name="authorBio" rows="3">{s.authorBio ?? ''}</textarea>
        </div>
        <div class="field half">
          <label>Location</label>
          <input name="location" value={s.location ?? ''} placeholder="Malaysia" />
        </div>
        <div class="field half">
          <label>Email</label>
          <input name="email" type="email" value={s.email ?? ''} />
        </div>
        <div class="field half">
          <label>Site URL</label>
          <input name="url" value={s.url ?? ''} placeholder="https://yourdomain.com" />
        </div>
        <div class="field half">
          <label>Twitter handle</label>
          <input name="twitterHandle" value={s.twitterHandle ?? ''} placeholder="@yourhandle" />
        </div>
      </div>
    </section>

    <!-- ── Work Experience ── -->
    <section class="form-section">
      <h2 class="form-section-title">Work Experience <span class="hint">(TJ's Journey — right side)</span></h2>
      <input type="hidden" id="work_count" name="work_count" value={workItems.length} />
      <div id="work-container">
        {workItems.map((job, i) => (
          <div class="array-item" data-idx={i}>
            <div class="array-item-header">
              <span class="array-item-num">#{i + 1}</span>
              <button type="button" class="btn-remove" onclick="removeArrayItem(this, 'work')">Remove</button>
            </div>
            <div class="fields">
              <div class="field half">
                <label>Company</label>
                <input name={`work_${i}_company`} value={job.company ?? ''} placeholder="Company name" />
              </div>
              <div class="field half">
                <label>Role</label>
                <input name={`work_${i}_role`} value={job.role ?? ''} placeholder="Product Owner · Automation Engineer" />
              </div>
              <div class="field half">
                <label>Period</label>
                <input name={`work_${i}_period`} value={job.period ?? ''} placeholder="2022 – Present" />
              </div>
              <div class="field half field-check">
                <label>Current role?</label>
                <label class="check-label">
                  <input type="checkbox" name={`work_${i}_current`} checked={job.current} />
                  <span>Yes, this is my current role</span>
                </label>
              </div>
              <div class="field">
                <label>Description</label>
                <textarea name={`work_${i}_description`} rows="2">{job.description ?? ''}</textarea>
              </div>
              <div class="field">
                <label>Tags <span class="hint">(comma-separated: n8n, MySQL, Notion)</span></label>
                <input name={`work_${i}_tags`} value={(job.tags ?? []).join(', ')} placeholder="n8n, MySQL, WhatsApp API" />
              </div>
            </div>
          </div>
        ))}
      </div>
      <button type="button" class="btn-add" onclick="addWorkItem()">+ Add work experience</button>
    </section>

    <!-- ── Education ── -->
    <section class="form-section">
      <h2 class="form-section-title">Education <span class="hint">(TJ's Journey — left side)</span></h2>
      <input type="hidden" id="edu_count" name="edu_count" value={eduItems.length} />
      <div id="edu-container">
        {eduItems.map((edu, i) => (
          <div class="array-item" data-idx={i}>
            <div class="array-item-header">
              <span class="array-item-num">#{i + 1}</span>
              <button type="button" class="btn-remove" onclick="removeArrayItem(this, 'edu')">Remove</button>
            </div>
            <div class="fields">
              <div class="field half">
                <label>School / University</label>
                <input name={`edu_${i}_school`} value={edu.school ?? ''} placeholder="University of Malaya" />
              </div>
              <div class="field half">
                <label>Degree / Programme</label>
                <input name={`edu_${i}_degree`} value={edu.degree ?? ''} placeholder="BSc Computer Science" />
              </div>
              <div class="field half">
                <label>Period</label>
                <input name={`edu_${i}_period`} value={edu.period ?? ''} placeholder="2016 – 2020" />
              </div>
              <div class="field half">
                <label>Tags <span class="hint">(comma-separated subjects)</span></label>
                <input name={`edu_${i}_tags`} value={(edu.tags ?? []).join(', ')} placeholder="Data Structures, Algorithms" />
              </div>
            </div>
          </div>
        ))}
      </div>
      <button type="button" class="btn-add" onclick="addEduItem()">+ Add education</button>
    </section>

    <!-- ── Social links ── -->
    <section class="form-section">
      <h2 class="form-section-title">Social links</h2>
      <div class="fields">
        {[
          { name: 'github',    label: 'GitHub',    placeholder: 'https://github.com/yourhandle' },
          { name: 'linkedin',  label: 'LinkedIn',  placeholder: 'https://linkedin.com/in/yourhandle' },
          { name: 'twitter',   label: 'Twitter/X', placeholder: 'https://twitter.com/yourhandle' },
          { name: 'facebook',  label: 'Facebook',  placeholder: 'https://facebook.com/yourpage' },
          { name: 'instagram', label: 'Instagram', placeholder: 'https://instagram.com/yourhandle' },
          { name: 'tiktok',    label: 'TikTok',    placeholder: 'https://tiktok.com/@yourhandle' },
          { name: 'youtube',   label: 'YouTube',   placeholder: 'https://youtube.com/@yourchannel' },
        ].map(f => (
          <div class="field half">
            <label>{f.label}</label>
            <input name={f.name} value={s.social?.[f.name] ?? ''} placeholder={f.placeholder} />
          </div>
        ))}
      </div>
    </section>

    <div class="form-actions">
      <button type="submit" class="btn-save" disabled={!configured}>Save & deploy</button>
    </div>
  </form>
</AdminLayout>

<script is:inline>
  // ── Work Experience ──────────────────────────────────
  function getWorkCount() {
    return document.querySelectorAll('#work-container .array-item').length;
  }
  function updateWorkCount() {
    document.getElementById('work_count').value = getWorkCount();
  }
  function reindexWork() {
    document.querySelectorAll('#work-container .array-item').forEach(function(item, i) {
      item.dataset.idx = i;
      item.querySelector('.array-item-num').textContent = '#' + (i + 1);
      item.querySelectorAll('[name]').forEach(function(input) {
        input.name = input.name.replace(/work_\d+_/, 'work_' + i + '_');
      });
    });
    updateWorkCount();
  }
  function addWorkItem() {
    var idx = getWorkCount();
    var container = document.getElementById('work-container');
    var div = document.createElement('div');
    div.className = 'array-item';
    div.dataset.idx = idx;
    div.innerHTML =
      '<div class="array-item-header"><span class="array-item-num">#' + (idx + 1) + '</span>' +
      '<button type="button" class="btn-remove" onclick="removeArrayItem(this,\'work\')">Remove</button></div>' +
      '<div class="fields">' +
        '<div class="field half"><label>Company</label><input name="work_' + idx + '_company" placeholder="Company name" /></div>' +
        '<div class="field half"><label>Role</label><input name="work_' + idx + '_role" placeholder="Product Owner" /></div>' +
        '<div class="field half"><label>Period</label><input name="work_' + idx + '_period" placeholder="2022 – Present" /></div>' +
        '<div class="field half field-check"><label>Current role?</label><label class="check-label"><input type="checkbox" name="work_' + idx + '_current" /><span>Yes, this is my current role</span></label></div>' +
        '<div class="field"><label>Description</label><textarea name="work_' + idx + '_description" rows="2"></textarea></div>' +
        '<div class="field"><label>Tags <span class="hint">(comma-separated)</span></label><input name="work_' + idx + '_tags" placeholder="n8n, MySQL" /></div>' +
      '</div>';
    container.appendChild(div);
    updateWorkCount();
  }

  // ── Education ──────────────────────────────────────
  function getEduCount() {
    return document.querySelectorAll('#edu-container .array-item').length;
  }
  function updateEduCount() {
    document.getElementById('edu_count').value = getEduCount();
  }
  function reindexEdu() {
    document.querySelectorAll('#edu-container .array-item').forEach(function(item, i) {
      item.dataset.idx = i;
      item.querySelector('.array-item-num').textContent = '#' + (i + 1);
      item.querySelectorAll('[name]').forEach(function(input) {
        input.name = input.name.replace(/edu_\d+_/, 'edu_' + i + '_');
      });
    });
    updateEduCount();
  }
  function addEduItem() {
    var idx = getEduCount();
    var container = document.getElementById('edu-container');
    var div = document.createElement('div');
    div.className = 'array-item';
    div.dataset.idx = idx;
    div.innerHTML =
      '<div class="array-item-header"><span class="array-item-num">#' + (idx + 1) + '</span>' +
      '<button type="button" class="btn-remove" onclick="removeArrayItem(this,\'edu\')">Remove</button></div>' +
      '<div class="fields">' +
        '<div class="field half"><label>School / University</label><input name="edu_' + idx + '_school" placeholder="University name" /></div>' +
        '<div class="field half"><label>Degree / Programme</label><input name="edu_' + idx + '_degree" placeholder="BSc Computer Science" /></div>' +
        '<div class="field half"><label>Period</label><input name="edu_' + idx + '_period" placeholder="2016 – 2020" /></div>' +
        '<div class="field half"><label>Tags</label><input name="edu_' + idx + '_tags" placeholder="Data Structures, Algorithms" /></div>' +
      '</div>';
    container.appendChild(div);
    updateEduCount();
  }

  // ── Shared remove ──────────────────────────────────
  function removeArrayItem(btn, type) {
    btn.closest('.array-item').remove();
    if (type === 'work') reindexWork();
    else reindexEdu();
  }
</script>

<style>
  .notice {
    background: #1a1200; border: 1px solid #3d2e00; color: #fbbf24;
    padding: 1rem 1.25rem; border-radius: 8px; margin-bottom: 1.5rem; font-size: 0.82rem; line-height: 1.7;
  }
  code { background: #2d2200; padding: 1px 5px; border-radius: 3px; font-family: monospace; font-size: 0.82em; }

  .alert { padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.82rem; margin-bottom: 1.25rem; }
  .alert-ok  { background: #0a1f15; border: 1px solid #064e3b; color: #34d399; }
  .alert-err { background: #1f0a0a; border: 1px solid #7f1d1d; color: #f87171; }

  .cms-form { display: flex; flex-direction: column; gap: 2rem; }

  .form-section {
    background: #1a1a1a; border: 1px solid #2d2d2d; border-radius: 8px; padding: 1.5rem;
  }
  .form-section-title { font-size: 0.82rem; font-weight: 500; color: #9ca3af; margin-bottom: 1.25rem; text-transform: uppercase; letter-spacing: 0.06em; }

  .fields { display: flex; flex-wrap: wrap; gap: 1rem; }
  .field { display: flex; flex-direction: column; gap: 6px; flex: 1 1 100%; }
  .field.half { flex: 1 1 calc(50% - 0.5rem); min-width: 200px; }
  .field-check { justify-content: flex-end; }

  label { font-size: 0.78rem; color: #6b7280; }
  .hint { color: #374151; font-size: 0.72rem; }

  .check-label {
    display: flex; align-items: center; gap: 8px; cursor: pointer;
    font-size: 0.82rem; color: #9ca3af;
  }
  .check-label input[type="checkbox"] { width: 14px; height: 14px; accent-color: #6366f1; }

  input, textarea {
    background: #111; border: 1px solid #2d2d2d; border-radius: 6px;
    color: #e5e7eb; font-family: inherit; font-size: 0.85rem;
    padding: 0.55rem 0.875rem; outline: none; transition: border-color 0.15s; width: 100%;
  }
  textarea { resize: vertical; line-height: 1.6; }
  input:focus, textarea:focus { border-color: #4b5563; }

  /* Array items */
  .array-item {
    background: #141414; border: 1px solid #222;
    border-radius: 6px; padding: 1rem; margin-bottom: 0.75rem;
  }
  .array-item:last-child { margin-bottom: 0; }
  .array-item-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 0.875rem;
  }
  .array-item-num { font-size: 0.72rem; color: #4b5563; font-weight: 500; }
  .btn-remove {
    font-size: 0.72rem; color: #ef4444; background: transparent;
    border: 1px solid #3f1e1e; border-radius: 4px; padding: 2px 8px;
    cursor: pointer; font-family: inherit; transition: background 0.15s;
  }
  .btn-remove:hover { background: #1f0a0a; }
  .btn-add {
    margin-top: 0.75rem; font-size: 0.8rem; color: #6366f1;
    background: transparent; border: 1px dashed #2d2d7a;
    border-radius: 6px; padding: 0.5rem 1rem; cursor: pointer;
    font-family: inherit; width: 100%; transition: background 0.15s, border-color 0.15s;
  }
  .btn-add:hover { background: rgba(99,102,241,0.06); border-color: #4444aa; }

  .form-actions { display: flex; justify-content: flex-end; }
  .btn-save {
    background: #f9fafb; border: none; border-radius: 6px; color: #0f0f0f;
    cursor: pointer; font-family: inherit; font-size: 0.85rem; font-weight: 500;
    padding: 0.6rem 1.5rem; transition: opacity 0.15s;
  }
  .btn-save:hover:not(:disabled) { opacity: 0.85; }
  .btn-save:disabled { opacity: 0.3; cursor: not-allowed; }
</style>
