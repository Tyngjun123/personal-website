---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getCollection } from 'astro:content';
import { scoreArticle, scoreBadge } from '../../lib/seoScore';

const articles = await getCollection('articles');
const projects = await getCollection('projects');
const certificates = await getCollection('certificates');

const published = articles.filter(a => !a.data.draft);
const drafts = articles.filter(a => a.data.draft);

// SEO health
const scores = published.map(a => scoreArticle(a.data));
const avgScore = scores.length
  ? Math.round(scores.reduce((s, r) => s + r.score, 0) / scores.length)
  : 0;
const goodCount = scores.filter(r => r.score >= 80).length;
const needsWork = scores.filter(r => r.score < 50).length;

const recentArticles = [...published]
  .sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime())
  .slice(0, 5);
---

<AdminLayout title="Dashboard">
  <!-- Stat cards -->
  <div class="cards">
    <div class="card">
      <div class="card-value">{published.length}</div>
      <div class="card-label">Published articles</div>
      {drafts.length > 0 && <div class="card-sub">{drafts.length} draft{drafts.length > 1 ? 's' : ''}</div>}
    </div>
    <div class="card">
      <div class="card-value">{projects.length}</div>
      <div class="card-label">Projects</div>
    </div>
    <div class="card">
      <div class="card-value">{certificates.length}</div>
      <div class="card-label">Certificates</div>
    </div>
    <div class="card">
      <div class="card-value">{avgScore}<span class="card-unit">/100</span></div>
      <div class="card-label">Avg SEO score</div>
      <div class="card-sub">{goodCount} good · {needsWork} need work</div>
    </div>
  </div>

  <!-- SEO quick summary -->
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">SEO health</h2>
      <a href="/admin/seo" class="section-link">View all →</a>
    </div>
    <div class="score-bars">
      {published.map(article => {
        const { score } = scoreArticle(article.data);
        const badge = scoreBadge(score);
        return (
          <div class="score-row">
            <span class="score-name">{article.data.title}</span>
            <div class="score-bar-wrap">
              <div class="score-bar" style={`width:${score}%; background:${badge.color}`}></div>
            </div>
            <span class="score-num" style={`color:${badge.color}`}>{score}</span>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Recent articles -->
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Recent articles</h2>
      <a href="/articles" target="_blank" class="section-link">View site →</a>
    </div>
    <table class="table">
      <thead>
        <tr>
          <th>Title</th>
          <th>Category</th>
          <th>Published</th>
          <th>Tags</th>
        </tr>
      </thead>
      <tbody>
        {recentArticles.map(a => (
          <tr>
            <td>
              <a href={`/articles/${a.slug}`} target="_blank" class="table-link">{a.data.title}</a>
            </td>
            <td><span class="badge">{a.data.category}</span></td>
            <td class="muted">{a.data.publishedDate}</td>
            <td class="muted">{a.data.tags.slice(0, 3).join(', ')}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</AdminLayout>

<style>
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .card {
    background: #1a1a1a;
    border: 1px solid #2d2d2d;
    border-radius: 8px;
    padding: 1.25rem;
  }

  .card-value {
    font-size: 1.75rem;
    font-weight: 600;
    color: #f9fafb;
    line-height: 1;
    margin-bottom: 6px;
  }

  .card-unit { font-size: 0.9rem; color: #4b5563; }
  .card-label { font-size: 0.78rem; color: #6b7280; }
  .card-sub { font-size: 0.72rem; color: #4b5563; margin-top: 4px; }

  .section { margin-bottom: 2.5rem; }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .section-title { font-size: 0.85rem; font-weight: 500; color: #d1d5db; }
  .section-link { font-size: 0.78rem; color: #4b5563; transition: color 0.15s; }
  .section-link:hover { color: #9ca3af; }

  /* Score bars */
  .score-bars { display: flex; flex-direction: column; gap: 10px; }

  .score-row {
    display: grid;
    grid-template-columns: 1fr 120px 36px;
    align-items: center;
    gap: 12px;
  }

  .score-name {
    font-size: 0.8rem;
    color: #9ca3af;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .score-bar-wrap {
    background: #1f1f1f;
    border-radius: 3px;
    height: 6px;
    overflow: hidden;
  }

  .score-bar { height: 100%; border-radius: 3px; transition: width 0.3s; }
  .score-num { font-size: 0.75rem; font-weight: 500; text-align: right; }

  /* Table */
  .table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
  }

  .table th {
    text-align: left;
    color: #4b5563;
    font-weight: 400;
    padding: 0 0.75rem 0.625rem;
    border-bottom: 1px solid #1f1f1f;
  }

  .table td {
    padding: 0.75rem;
    border-bottom: 1px solid #141414;
    color: #9ca3af;
  }

  .table-link { color: #d1d5db; transition: color 0.15s; }
  .table-link:hover { color: #f9fafb; }

  .badge {
    font-size: 0.7rem;
    padding: 2px 8px;
    border-radius: 4px;
    background: #1f2937;
    color: #6b7280;
  }

  .muted { color: #4b5563; }
</style>
