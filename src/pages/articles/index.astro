---
// src/pages/articles/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import ArticleThumbnailIcon from '../../components/ArticleThumbnailIcon.astro';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const articles = allArticles.sort(
  (a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime()
);
---

<BaseLayout title="Articles" description="Practical guides on automation, n8n, APIs, and workflow tools.">
  <div class="page-hero">
    <div class="container">
      <span class="eyebrow">// writing</span>
      <h1 class="page-title">Articles</h1>
      <p class="page-sub">Practical guides on automation, n8n, APIs, and workflow tools.</p>
    </div>
  </div>

  <section class="container page-body">
    {articles.length === 0 ? (
      <p class="empty">No articles yet — check back soon.</p>
    ) : (
      <ul class="articles-grid">
        {articles.map((article) => {
          const date = new Date(article.data.publishedDate).toLocaleDateString('en-MY', {
            year: 'numeric', month: 'short',
          });
          const catSlug = article.data.category.toLowerCase().replace(/\s+/g, '-');
          return (
            <li>
              <a href={`/articles/${article.slug}`} class="ac">
                <div class={`ac-img ac-img--${catSlug}`}>
                  {article.data.cover
                    ? <img src={article.data.cover} alt={article.data.title} loading="lazy" />
                    : <ArticleThumbnailIcon category={article.data.category} />
                  }
                  {article.data.featured && <div class="ac-img-bar"></div>}
                </div>
                <div class="ac-body">
                  <span class={`ac-cat ac-cat--${catSlug}`}>{article.data.category}</span>
                  <h2 class="ac-title">{article.data.title}</h2>
                  <p class="ac-desc">{article.data.description}</p>
                  <div class="ac-footer">
                    <time class="ac-date">{date}</time>
                    {article.data.readTime && <span class="ac-read">{article.data.readTime} read</span>}
                  </div>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(180deg, var(--bg) 0%, var(--white) 100%);
    border-bottom: 1px solid var(--border);
    padding: 48px 0 40px;
  }
  .eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--blue-500);
    margin-bottom: 8px;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .page-sub {
    font-size: 14px;
    color: var(--ink-3);
  }

  .page-body {
    padding: 40px 2rem 5rem;
  }
  .empty {
    font-size: 14px;
    color: var(--ink-4);
  }

  /* ── 3-col card grid ── */
  .articles-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }
  .articles-grid li { display: flex; }

  .ac {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--white);
    text-decoration: none;
    width: 100%;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .ac:hover {
    border-color: transparent;
    background: linear-gradient(var(--white), var(--white)) padding-box,
                linear-gradient(135deg, #2563eb 0%, #6366f1 55%, #a855f7 100%) border-box;
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(99, 102, 241, 0.12);
  }

  /* Thumbnail area */
  .ac-img {
    height: 130px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    flex-shrink: 0;
  }
  .ac-img img { width: 100%; height: 100%; object-fit: cover; }
  .ac-img-bar {
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: var(--gradient-bar);
  }
  .ac-img--automation,
  .ac-img--n8n         { background: var(--blue-50); }
  .ac-img--seo         { background: #f0fdf4; }
  .ac-img--dev,
  .ac-img--tutorial    { background: #f5f3ff; }
  .ac-img--tools       { background: #fffbeb; }
  .ac-img--productivity { background: #f0fdf4; }
  .ac-img--notion      { background: #f5f3ff; }
  .ac-img--database    { background: var(--blue-50); }

  /* Card body */
  .ac-body {
    padding: 14px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  /* Category badge */
  .ac-cat {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 4px;
    display: inline-block;
    margin-bottom: 8px;
    align-self: flex-start;
  }
  .ac-cat--automation,
  .ac-cat--n8n         { color: var(--blue-700); background: var(--blue-50); }
  .ac-cat--seo         { color: #065f46; background: #d1fae5; }
  .ac-cat--dev,
  .ac-cat--tutorial    { color: #5b21b6; background: #ede9fe; }
  .ac-cat--tools       { color: #92400e; background: #fef3c7; }
  .ac-cat--productivity { color: #065f46; background: #d1fae5; }
  .ac-cat--notion      { color: #5b21b6; background: #ede9fe; }
  .ac-cat--database    { color: var(--blue-700); background: var(--blue-50); }

  .ac-title {
    font-family: var(--font-display);
    font-size: 13.5px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.4;
    margin-bottom: 6px;
  }

  .ac-desc {
    font-size: 12px;
    color: var(--ink-3);
    line-height: 1.6;
    flex: 1;
    margin-bottom: 12px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ac-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    padding-top: 10px;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }
  .ac-date,
  .ac-read { font-family: var(--font-mono); font-size: 0.68rem; color: var(--ink-4); }

  @media (max-width: 900px) {
    .articles-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 540px) {
    .articles-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; }
    .ac-img { height: 80px; }
    .ac-body { padding: 10px; }
    .ac-title { font-size: 12px; }
    .ac-desc { -webkit-line-clamp: 2; font-size: 11px; }
    .page-body { padding: 24px 1rem 3rem; }
  }
</style>
