---
// src/pages/articles/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const articles = allArticles.sort(
  (a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime()
);
---

<BaseLayout title="Articles" description="Practical guides on automation, n8n, APIs, and workflow tools.">
  <div class="page-hero">
    <div class="container">
      <span class="eyebrow">// writing</span>
      <h1 class="page-title">Articles</h1>
      <p class="page-sub">Practical guides on automation, n8n, APIs, and workflow tools.</p>
    </div>
  </div>

  <section class="container page-body">
    {articles.length === 0 ? (
      <p class="empty">No articles yet — check back soon.</p>
    ) : (
      <ul class="article-list">
        {articles.map((article, i) => {
          const date = new Date(article.data.publishedDate).toLocaleDateString('en-MY', {
            year: 'numeric', month: 'short', day: 'numeric',
          });
          return (
            <li class="article-item">
              <a href={`/articles/${article.slug}`} class="article-link">
                <div class="article-left">
                  <span class="article-num">0{i + 1}</span>
                  <div class="article-body">
                    <div class="article-meta">
                      <span class="article-cat">{article.data.category}</span>
                      <span class="article-dot"></span>
                      <time datetime={article.data.publishedDate}>{date}</time>
                      {article.data.readTime && (
                        <>
                          <span class="article-dot"></span>
                          <span>{article.data.readTime} read</span>
                        </>
                      )}
                    </div>
                    <h2 class="article-title">{article.data.title}</h2>
                    <p class="article-desc">{article.data.description}</p>
                    <div class="article-tags">
                      {article.data.tags.slice(0, 4).map((tag: string) => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  </div>
                </div>
                <span class="article-arrow">→</span>
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(180deg, var(--bg) 0%, var(--white) 100%);
    border-bottom: 1px solid var(--border);
    padding: 48px 0 40px;
  }
  .eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--blue-500);
    margin-bottom: 8px;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .page-sub {
    font-size: 14px;
    color: var(--ink-3);
  }

  .page-body {
    padding: 40px 2rem 5rem;
  }
  .empty {
    font-size: 14px;
    color: var(--ink-4);
  }

  .article-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .article-item {
    border-bottom: 1px solid var(--border);
  }
  .article-item:first-child {
    border-top: 1px solid var(--border);
  }

  .article-link {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding: 24px 0;
    transition: opacity 0.15s;
  }
  .article-link:hover { opacity: 0.75; }
  .article-link:hover .article-arrow { transform: translateX(3px); }

  .article-left {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    flex: 1;
  }

  .article-num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-4);
    padding-top: 2px;
    width: 20px;
    flex-shrink: 0;
  }

  .article-body { flex: 1; }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--ink-3);
    margin-bottom: 8px;
    font-family: var(--font-mono);
    flex-wrap: wrap;
  }
  .article-cat {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--blue-700);
    background: var(--blue-50);
    padding: 3px 9px;
    border-radius: 4px;
    font-family: var(--font-mono);
  }
  .article-dot {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--ink-5);
  }

  .article-title {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.4;
    margin-bottom: 6px;
  }

  .article-desc {
    font-size: 13px;
    color: var(--ink-3);
    line-height: 1.65;
    margin-bottom: 10px;
    max-width: 620px;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 2px 8px;
    border-radius: 20px;
  }

  .article-arrow {
    font-size: 16px;
    color: var(--ink-4);
    padding-top: 20px;
    flex-shrink: 0;
    transition: transform 0.15s;
  }

  @media (max-width: 600px) {
    .article-arrow { display: none; }
    .article-left { gap: 10px; }
  }
</style>
