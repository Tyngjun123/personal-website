---
// src/pages/certificates/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allCerts = await getCollection('certificates');
const certs = allCerts.sort((a, b) => b.data.issuedDate.localeCompare(a.data.issuedDate));

const colorMap: Record<string, { bg: string; text: string }> = {
  teal:   { bg: '#e0f2fe', text: '#0369a1' },
  blue:   { bg: '#eff6ff', text: '#1d4ed8' },
  amber:  { bg: '#fefce8', text: '#92400e' },
  purple: { bg: '#f5f3ff', text: '#5b21b6' },
  coral:  { bg: '#fff1f2', text: '#9f1239' },
  gray:   { bg: '#f4f7ff', text: '#475569' },
} as any;
---

<BaseLayout title="Certificates" description="Certifications in automation, cloud, and product management.">
  <div class="page-hero">
    <div class="container">
      <span class="eyebrow">// credentials</span>
      <h1 class="page-title">Certificates</h1>
      <p class="page-sub">Certifications in automation, cloud, and product management.</p>
    </div>
  </div>

  <section class="container page-body">
    {certs.length === 0 ? (
      <p class="empty">No certificates yet — check back soon.</p>
    ) : (
      <ul class="cert-list">
        {certs.map(cert => {
          const color = colorMap[cert.data.color] ?? colorMap.gray;
          const date = new Date(cert.data.issuedDate + '-01').toLocaleDateString('en-MY', {
            year: 'numeric', month: 'short',
          });
          return (
            <li class="cert-item">
              <div class="cert-badge" style={`background:${color.bg}; color:${color.text}`}>
                {cert.data.issuerShort}
              </div>
              <div class="cert-info">
                <div class="cert-name">{cert.data.name}</div>
                <div class="cert-meta">
                  <span>{cert.data.issuer}</span>
                  <span class="cert-dot"></span>
                  <span>{date}</span>
                  {cert.data.expiryDate && (
                    <>
                      <span class="cert-dot"></span>
                      <span>Expires {cert.data.expiryDate}</span>
                    </>
                  )}
                </div>
                {cert.data.inProgress && (
                  <div class="cert-progress-wrap">
                    <div class="cert-progress-track">
                      <div class="cert-progress-fill" style={`width: ${cert.data.progress ?? 50}%`}></div>
                    </div>
                    <span class="cert-progress-label">In progress · {cert.data.progress ?? 50}%</span>
                  </div>
                )}
              </div>
              <div class="cert-right">
                <span class="cert-cat">{cert.data.category}</span>
                {cert.data.credentialUrl ? (
                  <a href={cert.data.credentialUrl} target="_blank" rel="noopener noreferrer" class="cert-link">
                    Verify ✓
                  </a>
                ) : (
                  <span class="cert-verified">✓ Verified</span>
                )}
              </div>
            </li>
          );
        })}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(180deg, var(--bg) 0%, var(--white) 100%);
    border-bottom: 1px solid var(--border);
    padding: 48px 0 40px;
  }
  .eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--blue-500);
    margin-bottom: 8px;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .page-sub {
    font-size: 14px;
    color: var(--ink-3);
  }

  .page-body {
    padding: 40px 2rem 5rem;
  }
  .empty {
    font-size: 14px;
    color: var(--ink-4);
  }

  .cert-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .cert-item {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 20px 0;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
  }
  .cert-item:first-child { border-top: 1px solid var(--border); }

  .cert-badge {
    width: 52px;
    height: 52px;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    flex-shrink: 0;
    letter-spacing: 0.04em;
  }

  .cert-info {
    flex: 1;
    min-width: 0;
  }
  .cert-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .cert-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    flex-wrap: wrap;
  }
  .cert-dot {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--ink-5);
    flex-shrink: 0;
  }

  /* Progress bar for in-progress certs */
  .cert-progress-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
  }
  .cert-progress-track {
    width: 120px;
    height: 4px;
    background: var(--blue-100);
    border-radius: 4px;
    overflow: hidden;
  }
  .cert-progress-fill {
    height: 4px;
    background: var(--blue-500);
    border-radius: 4px;
    animation: growBar 1s 0.3s cubic-bezier(0.4, 0, 0.2, 1) both;
  }
  .cert-progress-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--blue-500);
  }

  .cert-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    flex-shrink: 0;
  }
  .cert-cat {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    color: var(--ink-3);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 3px 9px;
    border-radius: 20px;
  }
  .cert-link {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--green);
    background: var(--green-bg);
    border: 1px solid var(--green-border);
    padding: 3px 10px;
    border-radius: 4px;
    transition: opacity 0.15s;
  }
  .cert-link:hover { opacity: 0.8; }
  .cert-verified {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--green);
  }

  @media (max-width: 600px) {
    .cert-item { flex-wrap: wrap; }
    .cert-right { flex-direction: row; align-items: center; width: 100%; }
  }
</style>
