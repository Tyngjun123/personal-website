---
// src/pages/certificates/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allCerts = await getCollection('certificates');
const certs = allCerts.sort((a, b) => b.data.issuedDate.localeCompare(a.data.issuedDate));

const colorMap: Record<string, { bg: string; text: string }> = {
  teal:   { bg: '#e0f2fe', text: '#0369a1' },
  blue:   { bg: '#eff6ff', text: '#1d4ed8' },
  amber:  { bg: '#fefce8', text: '#92400e' },
  purple: { bg: '#f5f3ff', text: '#5b21b6' },
  coral:  { bg: '#fff1f2', text: '#9f1239' },
  gray:   { bg: '#f4f7ff', text: '#475569' },
} as any;
---

<BaseLayout title="Certificates" description="Certifications in automation, cloud, and product management.">
  <div class="page-hero">
    <div class="container">
      <span class="eyebrow">// credentials</span>
      <h1 class="page-title">Certificates</h1>
      <p class="page-sub">Certifications in automation, cloud, and product management.</p>
    </div>
  </div>

  <section class="container page-body">
    {certs.length === 0 ? (
      <p class="empty">No certificates yet — check back soon.</p>
    ) : (
      <ul class="cert-list">
        {certs.map(cert => {
          const color = colorMap[cert.data.color] ?? colorMap.gray;
          const date = new Date(cert.data.issuedDate + '-01').toLocaleDateString('en-MY', {
            year: 'numeric', month: 'short',
          });
          return (
            <li
              class="cert-item"
              role="button"
              tabindex="0"
              data-modal="cert"
              data-name={cert.data.name}
              data-issuer={cert.data.issuer}
              data-issuer-short={cert.data.issuerShort}
              data-category={cert.data.category}
              data-color={cert.data.color}
              data-issued-date={date}
              data-expiry-date={cert.data.expiryDate ?? ''}
              data-credential-url={cert.data.credentialUrl ?? ''}
              data-description={cert.data.description ?? ''}
              data-in-progress={cert.data.inProgress ? 'true' : 'false'}
              data-progress={String(cert.data.progress ?? 0)}
            >
              <div class="cert-badge" style={`background:${color.bg}; color:${color.text}`}>
                {cert.data.issuerShort}
              </div>
              <div class="cert-info">
                <div class="cert-name">{cert.data.name}</div>
                <div class="cert-meta">
                  <span>{cert.data.issuer}</span>
                  <span class="cert-dot"></span>
                  <span>{date}</span>
                  {cert.data.expiryDate && (
                    <>
                      <span class="cert-dot"></span>
                      <span>Expires {cert.data.expiryDate}</span>
                    </>
                  )}
                </div>
                {cert.data.inProgress && (
                  <div class="cert-progress-wrap">
                    <div class="cert-progress-track">
                      <div class="cert-progress-fill" style={`width: ${cert.data.progress ?? 50}%`}></div>
                    </div>
                    <span class="cert-progress-label">In progress · {cert.data.progress ?? 50}%</span>
                  </div>
                )}
              </div>
              <div class="cert-right">
                <span class="cert-cat">{cert.data.category}</span>
                {cert.data.credentialUrl ? (
                  <a href={cert.data.credentialUrl} target="_blank" rel="noopener noreferrer" class="cert-link">
                    Verify ✓
                  </a>
                ) : (
                  <span class="cert-verified">✓ Verified</span>
                )}
              </div>
            </li>
          );
        })}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(180deg, var(--bg) 0%, var(--white) 100%);
    border-bottom: 1px solid var(--border);
    padding: 48px 0 40px;
  }
  .eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--blue-500);
    margin-bottom: 8px;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .page-sub {
    font-size: 14px;
    color: var(--ink-3);
  }

  .page-body {
    padding: 40px 2rem 5rem;
  }
  .empty {
    font-size: 14px;
    color: var(--ink-4);
  }

  .cert-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .cert-item {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 20px 0;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
    cursor: pointer;
  }
  .cert-item:first-child { border-top: 1px solid var(--border); }
  .cert-item:hover { background: var(--blue-50); }
  .cert-item:focus-visible { outline: 2px solid var(--blue-400); outline-offset: 2px; border-radius: var(--radius); }

  .cert-badge {
    width: 52px;
    height: 52px;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    flex-shrink: 0;
    letter-spacing: 0.04em;
  }

  .cert-info {
    flex: 1;
    min-width: 0;
  }
  .cert-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .cert-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    flex-wrap: wrap;
  }
  .cert-dot {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--ink-5);
    flex-shrink: 0;
  }

  /* Progress bar for in-progress certs */
  .cert-progress-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
  }
  .cert-progress-track {
    width: 120px;
    height: 4px;
    background: var(--blue-100);
    border-radius: 4px;
    overflow: hidden;
  }
  .cert-progress-fill {
    height: 4px;
    background: var(--blue-500);
    border-radius: 4px;
    animation: growBar 1s 0.3s cubic-bezier(0.4, 0, 0.2, 1) both;
  }
  .cert-progress-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--blue-500);
  }

  .cert-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    flex-shrink: 0;
  }
  .cert-cat {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    color: var(--ink-3);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 3px 9px;
    border-radius: 20px;
  }
  .cert-link {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--green);
    background: var(--green-bg);
    border: 1px solid var(--green-border);
    padding: 3px 10px;
    border-radius: 4px;
    transition: opacity 0.15s;
  }
  .cert-link:hover { opacity: 0.8; }
  .cert-verified {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--green);
  }

  @media (max-width: 600px) {
    .cert-item { flex-wrap: wrap; }
    .cert-right { flex-direction: row; align-items: center; width: 100%; }
  }
</style>

<script is:inline>
  // ── Modal controller ──────────────────────────────────
  const backdrop = document.getElementById('modal-backdrop');
  const panel    = document.getElementById('modal-panel');
  const closeBtn = document.getElementById('modal-close');

  function openModal() {
    backdrop.classList.add('open');
    panel.classList.add('open');
    panel.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    setTimeout(() => closeBtn && closeBtn.focus(), 50);
  }
  function closeModal() {
    backdrop.classList.remove('open');
    panel.classList.remove('open');
    panel.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  backdrop && backdrop.addEventListener('click', closeModal);
  closeBtn && closeBtn.addEventListener('click', closeModal);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && panel && panel.classList.contains('open')) closeModal();
  });

  // Swipe-down to close (mobile)
  var touchStartY = 0;
  panel && panel.addEventListener('touchstart', function(e) {
    touchStartY = e.touches[0].clientY;
  }, { passive: true });
  panel && panel.addEventListener('touchmove', function(e) {
    var dy = e.touches[0].clientY - touchStartY;
    if (dy > 0 && panel.scrollTop === 0) {
      panel.style.transform = 'translateY(' + Math.min(dy * 0.4, 80) + 'px)';
    }
  }, { passive: true });
  panel && panel.addEventListener('touchend', function(e) {
    var dy = e.changedTouches[0].clientY - touchStartY;
    panel.style.transform = '';
    if (dy > 80) closeModal();
  });

  function setText(id, value) {
    var el = document.getElementById(id);
    if (el) el.textContent = value || '';
  }
  function setHTML(id, value) {
    var el = document.getElementById(id);
    if (el) el.innerHTML = value || '';
  }
  function show(id) {
    var el = document.getElementById(id);
    if (el) el.style.display = '';
  }
  function hide(id) {
    var el = document.getElementById(id);
    if (el) el.style.display = 'none';
  }

  // ── Certificate modal ────────────────────────────────
  function openCertModal(data) {
    setText('modal-tag', data.category || '');

    var statusEl = document.getElementById('modal-status');
    if (statusEl) {
      if (data.inProgress === 'true') {
        statusEl.textContent = 'In Progress';
        statusEl.className = 'modal-status progress';
        statusEl.style.display = '';
      } else {
        statusEl.textContent = 'Verified';
        statusEl.className = 'modal-status live';
        statusEl.style.display = '';
      }
    }

    hide('modal-cover');

    setText('modal-title', data.name);
    setText('modal-desc', '');

    hide('modal-metrics');

    var contentHTML = '<p class="modal-cert-issuer">' + (data.issuer || '') + '</p>';
    contentHTML += '<div class="modal-cert-date">';
    contentHTML += '<div class="modal-cert-date-item">';
    contentHTML += '<span class="modal-cert-date-label">Issued</span>';
    contentHTML += '<span class="modal-cert-date-val">' + (data.issuedDate || '—') + '</span>';
    contentHTML += '</div>';
    if (data.expiryDate) {
      contentHTML += '<div class="modal-cert-date-item">';
      contentHTML += '<span class="modal-cert-date-label">Expires</span>';
      contentHTML += '<span class="modal-cert-date-val">' + data.expiryDate + '</span>';
      contentHTML += '</div>';
    }
    contentHTML += '</div>';
    if (data.description) {
      contentHTML += '<p class="modal-prose">' + data.description + '</p>';
    }
    if (data.inProgress === 'true' && data.progress && parseInt(data.progress) > 0) {
      contentHTML += '<p class="modal-section-label">Progress</p>' +
        '<div style="display:flex;align-items:center;gap:10px;margin-top:4px;">' +
          '<div style="flex:1;height:6px;background:var(--blue-100);border-radius:4px;overflow:hidden;">' +
            '<div style="height:6px;width:' + data.progress + '%;background:var(--blue-500);border-radius:4px;"></div>' +
          '</div>' +
          '<span style="font-family:var(--font-mono);font-size:11px;color:var(--blue-500);">' + data.progress + '%</span>' +
        '</div>';
    }
    setHTML('modal-content', contentHTML);

    hide('modal-stack');

    if (data.credentialUrl) {
      setHTML('modal-links', '<a href="' + data.credentialUrl + '" target="_blank" rel="noopener" class="modal-link-btn primary">Verify credential →</a>');
      show('modal-links');
    } else {
      hide('modal-links');
    }

    openModal();
  }

  // ── Bind cert items ───────────────────────────────────
  document.querySelectorAll('[data-modal="cert"]').forEach(function(item) {
    function open() {
      openCertModal({
        name:          item.dataset.name,
        issuer:        item.dataset.issuer,
        issuerShort:   item.dataset.issuerShort,
        category:      item.dataset.category,
        color:         item.dataset.color,
        issuedDate:    item.dataset.issuedDate,
        expiryDate:    item.dataset.expiryDate || '',
        credentialUrl: item.dataset.credentialUrl || '',
        description:   item.dataset.description || '',
        inProgress:    item.dataset.inProgress,
        progress:      item.dataset.progress,
      });
    }
    // Don't trigger modal when clicking the Verify link directly
    item.addEventListener('click', function(e) {
      if (e.target.closest('a')) return;
      open();
    });
    item.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(); }
    });
  });
</script>
