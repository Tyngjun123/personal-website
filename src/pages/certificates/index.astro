---
// src/pages/certificates/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allCerts = await getCollection('certificates');
const certs = allCerts.sort((a, b) => b.data.issuedDate.localeCompare(a.data.issuedDate));

const colorMap: Record<string, { bg: string; text: string }> = {
  teal:   { bg: '#e0f2fe', text: '#0369a1' },
  blue:   { bg: '#eff6ff', text: '#1d4ed8' },
  amber:  { bg: '#fefce8', text: '#92400e' },
  purple: { bg: '#f5f3ff', text: '#5b21b6' },
  coral:  { bg: '#fff1f2', text: '#9f1239' },
  gray:   { bg: '#f4f7ff', text: '#475569' },
} as any;
---

<BaseLayout title="Certificates" description="Certifications in automation, cloud, and product management.">
  <div class="page-hero">
    <div class="container">
      <span class="eyebrow">// credentials</span>
      <h1 class="page-title">Certificates</h1>
      <p class="page-sub">Certifications in automation, cloud, and product management.</p>
    </div>
  </div>

  <section class="container page-body">
    {certs.length === 0 ? (
      <p class="empty">No certificates yet — check back soon.</p>
    ) : (
      <ul class="cert-grid">
        {certs.map(cert => {
          const color = colorMap[cert.data.color] ?? colorMap.gray;
          const date = new Date(cert.data.issuedDate + '-01').toLocaleDateString('en-MY', {
            year: 'numeric', month: 'short',
          });
          const expiry = cert.data.expiryDate
            ? new Date(cert.data.expiryDate + '-01').toLocaleDateString('en-MY', { year: 'numeric', month: 'short' })
            : null;
          const Tag = cert.data.credentialUrl ? 'a' : 'div';
          return (
            <li>
              <Tag
                class="cert-card"
                href={cert.data.credentialUrl ?? undefined}
                target={cert.data.credentialUrl ? '_blank' : undefined}
                rel={cert.data.credentialUrl ? 'noopener noreferrer' : undefined}
              >
                {/* Logo / badge */}
                <div class="cert-logo" style={`background:${color.bg}`}>
                  {cert.data.logo ? (
                    <img
                      src={cert.data.logo}
                      alt={cert.data.issuerShort}
                      width="40" height="40"
                      style="object-fit:contain; border-radius:8px;"
                      onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                    />
                  ) : null}
                  <span
                    class="cert-logo-text"
                    style={`color:${color.text}; display:${cert.data.logo ? 'none' : 'flex'}`}
                  >
                    {cert.data.issuerShort}
                  </span>
                </div>

                {/* Main content */}
                <div class="cert-body">
                  <div class="cert-name">{cert.data.name}</div>
                  <div class="cert-issuer">{cert.data.issuer}</div>
                  <div class="cert-dates">
                    <span>Issued {date}</span>
                    {expiry && <span>· Expires {expiry}</span>}
                  </div>
                  {cert.data.description && (
                    <p class="cert-desc">{cert.data.description}</p>
                  )}
                  {cert.data.inProgress && (
                    <div class="cert-progress-wrap">
                      <div class="cert-progress-track">
                        <div class="cert-progress-fill" style={`width: ${cert.data.progress ?? 50}%`}></div>
                      </div>
                      <span class="cert-progress-label">In progress · {cert.data.progress ?? 50}%</span>
                    </div>
                  )}
                </div>

                {/* Footer */}
                <div class="cert-footer">
                  <span class="cert-cat">{cert.data.category}</span>
                  {cert.data.credentialUrl ? (
                    <span class="cert-verify">Verify ↗</span>
                  ) : (
                    <span class="cert-verified">✓ Verified</span>
                  )}
                </div>
              </Tag>
            </li>
          );
        })}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(180deg, var(--bg) 0%, var(--white) 100%);
    border-bottom: 1px solid var(--border);
    padding: 48px 0 40px;
  }
  .eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--blue-500);
    margin-bottom: 8px;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .page-sub {
    font-size: 14px;
    color: var(--ink-3);
  }

  .page-body {
    padding: 40px 2rem 5rem;
  }
  .empty {
    font-size: 14px;
    color: var(--ink-4);
  }

  /* ── 3-col card grid ── */
  .cert-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }
  .cert-grid li { display: flex; }

  .cert-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 20px;
    background: var(--white);
    text-decoration: none;
    color: inherit;
    width: 100%;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  a.cert-card:hover {
    border-color: var(--blue-200);
    box-shadow: 0 8px 24px rgba(37, 99, 235, 0.10);
    transform: translateY(-3px);
  }
  a.cert-card:focus-visible {
    outline: 2px solid var(--blue-400);
    outline-offset: 2px;
    border-radius: var(--radius-lg);
  }

  /* Logo area */
  .cert-logo {
    width: 56px;
    height: 56px;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
    border: 1px solid var(--border);
    margin-bottom: 14px;
  }
  .cert-logo-text {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4px;
  }

  /* Body */
  .cert-body { flex: 1; }

  .cert-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.4;
    margin-bottom: 4px;
  }
  .cert-issuer {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--blue-600);
    margin-bottom: 4px;
  }
  .cert-dates {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--ink-4);
    margin-bottom: 8px;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .cert-desc {
    font-size: 11.5px;
    color: var(--ink-4);
    line-height: 1.6;
    margin-bottom: 12px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Progress bar */
  .cert-progress-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }
  .cert-progress-track {
    flex: 1;
    height: 4px;
    background: var(--blue-100);
    border-radius: 4px;
    overflow: hidden;
  }
  .cert-progress-fill {
    height: 4px;
    background: var(--blue-500);
    border-radius: 4px;
    animation: growBar 1s 0.3s cubic-bezier(0.4, 0, 0.2, 1) both;
  }
  .cert-progress-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--blue-500);
    white-space: nowrap;
  }

  /* Footer */
  .cert-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }
  .cert-cat {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    color: var(--ink-3);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 3px 9px;
    border-radius: 20px;
  }
  .cert-verify {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--green);
    background: var(--green-bg);
    border: 1px solid var(--green-border);
    padding: 3px 10px;
    border-radius: 4px;
  }
  .cert-verified {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--green);
  }

  @media (max-width: 900px) {
    .cert-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 540px) {
    .cert-grid { grid-template-columns: 1fr; }
    .page-body { padding: 24px 1rem 3rem; }
  }
</style>
