---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../config/site';
import ArticleThumbnailIcon from '../components/ArticleThumbnailIcon.astro';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 4);

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const latestArticles = allArticles
  .sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime())
  .slice(0, 4);

const workExperience = SITE.workExperience;
const education = SITE.education;

// Merge + sort newest→oldest by the first 4-digit year in `period`
const getYear = (period: string) => parseInt(period.match(/\d{4}/)?.[0] ?? '0', 10);
const allJourneyItems = [
  ...workExperience.map((job: any) => ({ ...job, side: 'work' })),
  ...education.map((edu: any)     => ({ ...edu, side: 'edu'  })),
].sort((a: any, b: any) => getYear(b.period) - getYear(a.period));
---

<BaseLayout title={SITE.title} description={SITE.description}>

  <!-- ══ HERO ══ -->
  <section class="hero">
    <div class="hero-mesh" aria-hidden="true">
      <div class="mesh-blob mesh-blob-1"></div>
      <div class="mesh-blob mesh-blob-2"></div>
      <div class="mesh-blob mesh-blob-3"></div>
      <div class="mesh-dots"></div>
      <div class="mesh-ring mesh-ring-1"></div>
      <div class="mesh-ring mesh-ring-2"></div>
    </div>

    <div class="container hero-inner">
      <!-- Text content (in DOM first; photo uses order:-1 on mobile to appear above) -->
      <div class="hero-left">
        <div class="hero-badge anim-1">
          <span class="hero-badge-dot"></span>
          <span class="hero-badge-text">{SITE.authorRole} · {SITE.location}</span>
        </div>

        <h1 class="hero-h1 anim-2">
          Hi, I'm {SITE.author}.<br />
          <span class="hero-h1-grad">I build systems</span><br />
          that think.
        </h1>

        <p class="hero-typewriter anim-3">
          <span id="typewriter-text"></span><span class="typewriter-cursor"></span>
        </p>

        <p class="hero-desc anim-4">{SITE.authorBio}</p>

        <div class="hero-btns anim-5">
          <a href="/projects" class="btn-primary">View Projects</a>
          <a href="/articles" class="btn-ghost">Read Articles</a>
        </div>

        <div class="hero-stats anim-5">
          <div class="stat">
            <div class="stat-val" data-target="20" data-suffix="+">20+</div>
            <div class="stat-label">Automations built</div>
          </div>
          <div class="stat">
            <div class="stat-val" data-target="80" data-suffix="%">80%</div>
            <div class="stat-label">Manual work cut</div>
          </div>
          <div class="stat">
            <div class="stat-val" data-target="60" data-suffix="s">60s</div>
            <div class="stat-label">Lead response</div>
          </div>
        </div>
      </div>

      <!-- Photo (order:-1 on mobile = above text) -->
      <div class="hero-photo anim-photo">
        <div class="photo-wrap">
          <div class="photo-ring-outer"></div>
          <div class="photo-ring-mid"></div>
          <div class="photo-gradient-ring">
            <div class="photo-gradient-ring-inner"></div>
          </div>
          <div class="photo-circle">
            <img
              src="/tj-photo.png"
              alt={SITE.author}
              loading="eager"
              style="width:100%;height:100%;border-radius:50%;object-fit:cover;object-position:center top;"
            />
          </div>
          <div class="photo-dot photo-dot-1"></div>
          <div class="photo-dot photo-dot-2"></div>
          <div class="photo-dot photo-dot-3"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ MARQUEE TICKER ══ -->
  <div class="ticker-wrap" aria-hidden="true">
    <div class="ticker-track">
      {[0, 1].map(() => (
        <div class="ticker-set">
          <span class="ticker-item"><span class="ticker-dot"></span>Product Owner</span>
          <span class="ticker-item"><span class="ticker-dot"></span>n8n Automation</span>
          <span class="ticker-item"><span class="ticker-dot"></span>API Integration</span>
          <span class="ticker-item"><span class="ticker-dot"></span>WhatsApp &amp; Telegram Bots</span>
          <span class="ticker-item"><span class="ticker-dot"></span>MySQL &amp; Databases</span>
          <span class="ticker-item"><span class="ticker-dot"></span>Workflow Architecture</span>
          <span class="ticker-item"><span class="ticker-dot"></span>SEO Automation</span>
          <span class="ticker-item"><span class="ticker-dot"></span>Notion Systems</span>
          <span class="ticker-item"><span class="ticker-dot"></span>Process Elimination</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ══ TJ'S JOURNEY ══ -->
  <section class="journey-section reveal-section">
    <div class="journey-bg" aria-hidden="true">
      <div class="journey-glow journey-glow-1"></div>
      <div class="journey-glow journey-glow-2"></div>
      <span class="journey-watermark journey-watermark--left">EDUCATION</span>
      <span class="journey-watermark journey-watermark--right">WORK</span>
    </div>
    <div class="container">
      <div class="journey-header">
        <p class="journey-eyebrow">// timeline</p>
        <h2 class="journey-title">TJ's <span>Journey</span></h2>
      </div>

      <div class="jt-wrap">
        <!-- Vertical line -->
        <div class="jt-vline" aria-hidden="true"></div>

        <!-- Column labels -->
        <div class="jt-cell jt-cell--left"><span class="jt-col-label">Education</span></div>
        <div class="jt-cell jt-cell--center"></div>
        <div class="jt-cell jt-cell--right"><span class="jt-col-label">Work Experience</span></div>

        <!-- All items merged & sorted newest→oldest: edu=LEFT, work=RIGHT -->
        {(allJourneyItems as any[]).map((item, i) => (
          <>
            {/* LEFT cell: edu card -or- work date */}
            <div class="jt-cell jt-cell--left reveal-item" style={`transition-delay: ${i * 0.1}s`}>
              {item.side === 'edu' ? (
                <div class="jt-card">
                  <div class="jt-card-name">{item.school}</div>
                  <div class="jt-card-sub">{item.degree}</div>
                  {item.tags && item.tags.length > 0 && (
                    <div class="jt-tags">
                      {item.tags.map((t: string) => <span class="jt-tag">{t}</span>)}
                    </div>
                  )}
                </div>
              ) : (
                <span class="jt-period jt-period--right">{item.period}</span>
              )}
            </div>

            {/* CENTER: dot on the line */}
            <div class="jt-cell jt-cell--center">
              <div class:list={['jt-dot', { 'jt-dot--current': item.side === 'work' && item.current }]}></div>
            </div>

            {/* RIGHT cell: work card -or- edu date */}
            <div class="jt-cell jt-cell--right reveal-item" style={`transition-delay: ${i * 0.1}s`}>
              {item.side === 'work' ? (
                <div class:list={['jt-card', { 'jt-card--current': item.current }]}>
                  <div class="jt-card-name">{item.company}</div>
                  <div class="jt-card-sub">{item.role}</div>
                  {item.description && <p class="jt-card-desc">{item.description}</p>}
                  {item.tags && item.tags.length > 0 && (
                    <div class="jt-tags">
                      {item.tags.map((t: string) => <span class="jt-tag">{t}</span>)}
                    </div>
                  )}
                </div>
              ) : (
                <span class="jt-period">{item.period}</span>
              )}
            </div>
          </>
        ))}

      </div>
    </div>
  </section>

  <!-- ══ SKILLS ══ -->
  <section class="section-skills reveal-section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">// skills</span>
        <h2 class="section-title">What I <span class="title-grad">work with</span></h2>
      </div>
      <div class="skills-about-grid">
        <div class="about-text">
          <p>Product Owner in Malaysia. I don't manage backlogs — I eliminate entire categories of work by automating them out of existence.</p>
          <p>My tools of choice are n8n, MySQL, Notion, and a growing stack of APIs. I care about solutions that are practical, cost-effective, and actually get used.</p>
        </div>
        <div class="skills-grid">
          {[
            { name: 'n8n / Automation',    pct: 92 },
            { name: 'Website Development',     pct: 88 },
            { name: 'CRM System Development',    pct: 82 },
            { name: 'WhatsApp + Telegram Bots Messaging', pct: 78 },
            { name: 'SEO',      pct: 72 },
            { name: 'Notion',      pct: 90 },
          ].map(s => (
            <div class="skill-row">
              <div class="skill-head">
                <span class="skill-name">{s.name}</span>
                <span class="skill-pct">{s.pct}%</span>
              </div>
              <div class="skill-track">
                <div class="skill-fill" style={`width: ${s.pct}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ PROJECTS ══ -->
  <section class="section-projects reveal-section">
    <div class="container">
      <div class="section-header section-header--row">
        <div>
          <span class="eyebrow">// selected work</span>
          <h2 class="section-title">Systems <span class="title-grad">built</span></h2>
        </div>
        <a href="/projects" class="section-link">All projects →</a>
      </div>

      <div class="projects-grid">
        {featuredProjects.length > 0 ? featuredProjects.map((project, i) => (
          <div class:list={['proj-card', { 'proj-featured': i < 2 }]}>
            {i < 2 && <div class="proj-top-bar" aria-hidden="true"></div>}
            <div class="proj-blob" aria-hidden="true"></div>
            <span class="proj-tag">{project.data.category}</span>
            <h3 class="proj-title">{project.data.title}</h3>
            <p class="proj-desc">{project.data.description}</p>
            <div class="proj-stack">
              {project.data.tags.slice(0, 4).map((tag: string) => (
                <span class="stack-pill">{tag}</span>
              ))}
            </div>
            {project.data.metrics && project.data.metrics.length > 0 && (
              <span class="result-badge">✓ {project.data.metrics[0].value} {project.data.metrics[0].label}</span>
            )}
          </div>
        )) : (
          <>
            {[
              { tag: 'Automation', title: 'Lead management & multi-channel notification system', desc: 'Zero-touch pipeline from form submission to WhatsApp, Telegram, and Email in under 60 seconds.', stack: ['n8n', 'MySQL', 'WhatsApp API', 'Notion'], result: '↓ 80% reduction in manual effort', featured: true },
              { tag: 'SEO × AI',   title: 'SEO keyword research automation pipeline',           desc: 'Scrapes Google Autocomplete + Reddit → Gemini generates full articles in under 5 minutes.', stack: ['n8n', 'Gemini API', 'Google Sheets'], result: '↓ Full article pipeline in < 5 min', featured: true },
              { tag: 'Platform',  title: 'Telegram bot promotion system',                       desc: 'Automated weekly bonus campaigns with smart rate limiting for platform members.', stack: ['Telegram API', 'Node.js', 'MySQL'], result: null, featured: false },
              { tag: 'Tracking',  title: 'Wealth management tracker in Notion',                 desc: 'Portfolio dashboard with live charts and automated data sync via n8n workflows.', stack: ['Notion API', 'n8n', 'Charts'], result: null, featured: false },
            ].map((p, i) => (
              <div class:list={['proj-card', { 'proj-featured': p.featured }]}>
                {p.featured && <div class="proj-top-bar" aria-hidden="true"></div>}
                <div class="proj-blob" aria-hidden="true"></div>
                <span class="proj-tag">{p.tag}</span>
                <h3 class="proj-title">{p.title}</h3>
                <p class="proj-desc">{p.desc}</p>
                <div class="proj-stack">
                  {p.stack.map((t: string) => <span class="stack-pill">{t}</span>)}
                </div>
                {p.result && <span class="result-badge">{p.result}</span>}
              </div>
            ))}
          </>
        )}
      </div>
    </div>
  </section>

  <!-- ══ ARTICLES — CARD GRID ══ -->
  <section class="section-articles reveal-section">
    <div class="container">
      <div class="section-header section-header--row">
        <div>
          <span class="eyebrow">// writing</span>
          <h2 class="section-title">Latest <span class="title-grad">articles</span></h2>
        </div>
        <a href="/articles" class="section-link">View all →</a>
      </div>

      <div class="articles-card-grid">
        {latestArticles.length > 0 ? latestArticles.map(article => (
          <a href={`/articles/${article.slug}`} class="article-card">
            <div class={`article-card-img article-card-img--${article.data.category.toLowerCase().replace(/\s+/g, '-')}`}>
              {article.data.cover
                ? <img src={article.data.cover} alt={article.data.title} loading="lazy" />
                : <ArticleThumbnailIcon category={article.data.category} />
              }
              {article.data.featured && <div class="article-card-top-bar"></div>}
            </div>
            <div class="article-card-body">
              <span class={`article-cat-badge article-cat-badge--${article.data.category.toLowerCase().replace(/\s+/g, '-')}`}>
                {article.data.category}
              </span>
              <h3 class="article-card-title">{article.data.title}</h3>
              <p class="article-card-excerpt">{article.data.description}</p>
              <div class="article-card-footer">
                <time class="article-card-date">{new Date(article.data.publishedDate).toLocaleDateString('en-MY', { month: 'short', year: 'numeric' })}</time>
                {article.data.readTime && <span class="article-card-read">{article.data.readTime} read</span>}
              </div>
            </div>
          </a>
        )) : (
          [
            { slug: '#', category: 'Automation', title: 'Building a lead automation pipeline with n8n', description: 'A complete walkthrough of building a zero-touch lead pipeline.', publishedDate: '2025-03-01', readTime: '8 min', featured: true },
            { slug: '#', category: 'Tools',       title: 'n8n vs Zapier: which one actually saves time?', description: 'A real comparison from someone who uses both in production.',       publishedDate: '2025-02-01', readTime: '6 min', featured: false },
            { slug: '#', category: 'Productivity', title: 'Notion API automation guide for product owners', description: 'How to automate your Notion workspace with the API.',              publishedDate: '2025-01-01', readTime: '5 min', featured: false },
          ].map(article => (
            <a href={`/articles/${article.slug}`} class="article-card">
              <div class={`article-card-img article-card-img--${article.category.toLowerCase().replace(/\s+/g, '-')}`}>
                <ArticleThumbnailIcon category={article.category} />
                {article.featured && <div class="article-card-top-bar"></div>}
              </div>
              <div class="article-card-body">
                <span class={`article-cat-badge article-cat-badge--${article.category.toLowerCase().replace(/\s+/g, '-')}`}>
                  {article.category}
                </span>
                <h3 class="article-card-title">{article.title}</h3>
                <p class="article-card-excerpt">{article.description}</p>
                <div class="article-card-footer">
                  <time class="article-card-date">{new Date(article.publishedDate).toLocaleDateString('en-MY', { month: 'short', year: 'numeric' })}</time>
                  <span class="article-card-read">{article.readTime} read</span>
                </div>
              </div>
            </a>
          ))
        )}
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
  // ── Typewriter ────────────────────────────────────────
  var roles = [
    'Product Owner',
    'n8n Automation Engineer',
    'API Integration Specialist',
    'Workflow Architect',
  ];
  var rIdx = 0, cIdx = 0, deleting = false;
  var twEl = document.getElementById('typewriter-text');
  function typeStep() {
    if (!twEl) return;
    var current = roles[rIdx];
    if (!deleting) {
      twEl.textContent = current.slice(0, ++cIdx);
      if (cIdx === current.length) { deleting = true; setTimeout(typeStep, 1800); return; }
      setTimeout(typeStep, 80);
    } else {
      twEl.textContent = current.slice(0, --cIdx);
      if (cIdx === 0) { deleting = false; rIdx = (rIdx + 1) % roles.length; setTimeout(typeStep, 300); return; }
      setTimeout(typeStep, 40);
    }
  }
  typeStep();

  // ── Count-up on scroll ────────────────────────────────
  var countObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (!entry.isIntersecting) return;
      var el = entry.target;
      var target = parseInt(el.dataset.target, 10);
      var suffix = el.dataset.suffix || '';
      var current = 0;
      var steps = 40;
      var increment = target / steps;
      var interval = 1000 / steps;
      var timer = setInterval(function() {
        current = Math.min(current + increment, target);
        el.textContent = Math.round(current) + suffix;
        if (current >= target) clearInterval(timer);
      }, interval);
      countObserver.unobserve(el);
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('.stat-val[data-target]').forEach(function(el) {
    countObserver.observe(el);
  });

  // ── Scroll reveal ─────────────────────────────────────
  var revealObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (!entry.isIntersecting) return;
      entry.target.classList.add('revealed');
      var items = entry.target.querySelectorAll('.reveal-item');
      items.forEach(function(child, i) {
        setTimeout(function() { child.classList.add('revealed'); }, i * 80);
      });
      revealObserver.unobserve(entry.target);
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal-section').forEach(function(el) {
    revealObserver.observe(el);
  });
</script>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--white);
    border-bottom: 1px solid var(--border);
  }

  /* Mesh background */
  .hero-mesh { position: absolute; inset: 0; pointer-events: none; }
  .mesh-blob { position: absolute; border-radius: 50%; }
  .mesh-blob-1 {
    top: -100px; right: -80px; width: 420px; height: 420px;
    background: radial-gradient(circle, rgba(99,102,241,0.13) 0%, rgba(59,130,246,0.06) 40%, transparent 70%);
  }
  .mesh-blob-2 {
    bottom: -80px; left: -50px; width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(168,85,247,0.09) 0%, transparent 65%);
  }
  .mesh-blob-3 {
    top: 35%; right: 25%; width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(6,182,212,0.08) 0%, transparent 70%);
  }
  .mesh-dots {
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, #bfdbfe 1px, transparent 1px);
    background-size: 28px 28px; opacity: 0.28;
  }
  .mesh-ring {
    position: absolute; border-radius: 50%;
    border: 1px solid rgba(99,102,241,0.07);
  }
  .mesh-ring-1 { top: -120px; right: -120px; width: 500px; height: 500px; }
  .mesh-ring-2 { top: -80px;  right: -80px;  width: 420px; height: 420px; border-color: rgba(59,130,246,0.05); }

  /* Hero inner layout */
  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    z-index: 1;
    padding-top: 40px;
    padding-bottom: 56px;
    gap: 0;
  }
  @media (min-width: 1024px) {
    .hero-inner {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 48px;
      align-items: center;
      text-align: left;
      padding-top: 64px;
    }
  }

  /* Left text col */
  .hero-left { width: 100%; }

  /* Badge */
  .hero-badge {
    display: inline-flex; align-items: center; gap: 7px;
    font-family: var(--font-mono); font-size: 11px; font-weight: 500;
    letter-spacing: 0.1em; text-transform: uppercase;
    background: var(--white); border: 1px solid var(--blue-200);
    padding: 5px 13px; border-radius: 20px; margin-bottom: 20px;
  }
  .hero-badge-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--blue-500);
    animation: pulse-dot 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  .hero-badge-text {
    background: var(--gradient-alt);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* H1 */
  .hero-h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3rem);
    font-weight: 800; line-height: 1.08; letter-spacing: -0.03em;
    color: var(--ink); margin-bottom: 12px;
  }
  .hero-h1-grad {
    background: var(--gradient);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Typewriter */
  .hero-typewriter {
    font-family: var(--font-mono); font-size: 13px; color: var(--blue-500);
    margin-bottom: 16px; min-height: 20px;
    display: flex; align-items: center; justify-content: center; gap: 2px;
  }
  @media (min-width: 1024px) {
    .hero-typewriter { justify-content: flex-start; }
  }
  .typewriter-cursor {
    display: inline-block; width: 2px; height: 15px;
    background: var(--blue-500);
    animation: blink 1s step-end infinite;
    vertical-align: middle;
  }

  /* Description */
  .hero-desc {
    font-size: 14px; color: var(--ink-3); line-height: 1.8;
    max-width: 440px; margin: 0 auto 32px;
  }
  @media (min-width: 1024px) {
    .hero-desc { margin-left: 0; }
  }

  /* CTA buttons */
  .hero-btns {
    display: flex; gap: 12px; flex-wrap: wrap;
    justify-content: center; margin-bottom: 0;
  }
  @media (min-width: 1024px) {
    .hero-btns { justify-content: flex-start; }
  }
  .btn-primary {
    font-size: 13px; font-weight: 600; padding: 10px 22px;
    background: var(--blue-600); color: #fff; border-radius: var(--radius);
    transition: background 0.15s, transform 0.15s; display: inline-block;
  }
  .btn-primary:hover { background: var(--blue-700); transform: translateY(-1px); }
  .btn-ghost {
    font-size: 13px; font-weight: 500; padding: 10px 22px;
    border: 1.5px solid var(--border); color: var(--ink-2);
    border-radius: var(--radius); transition: border-color 0.15s, background 0.15s;
    display: inline-block;
  }
  .btn-ghost:hover { border-color: var(--blue-200); background: var(--blue-50); }

  /* Stats */
  .hero-stats {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 0; padding-top: 24px;
    border-top: 1px solid var(--border); margin-top: 32px;
  }
  .stat { padding: 0 16px 0 0; }
  .stat:first-child { padding-left: 0; }
  .stat-val {
    display: block; font-family: var(--font-display); font-size: 28px; font-weight: 800;
    background: var(--gradient);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .stat-label { display: block; font-size: 11px; font-weight: 500; color: var(--ink-4); text-transform: uppercase; letter-spacing: 0.04em; margin-top: 2px; }

  /* ── Photo frame ── */
  .hero-photo {
