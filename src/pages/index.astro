---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../config/site';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 4);

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const latestArticles = allArticles
  .sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime())
  .slice(0, 3);
---

<BaseLayout title={SITE.title} description={SITE.description}>

  <!-- ══ HERO ══ -->
  <section class="hero">
    <!-- Background decorations -->
    <div class="hero-blob-tr" aria-hidden="true"></div>
    <div class="hero-blob-bl" aria-hidden="true"></div>
    <div class="hero-dots" aria-hidden="true"></div>

    <div class="container hero-inner">
      <!-- Left column -->
      <div class="hero-left">
        <div class="hero-badge anim-1">
          <span class="badge-dot"></span>
          AI Automation Engineer · Malaysia
        </div>

        <h1 class="hero-h1 anim-2">
          <span class="h1-plain">Hi, I'm TJ.</span><br />
          <span class="h1-gradient">I build systems</span><br />
          <span class="h1-plain">that think.</span>
        </h1>

        <p class="hero-desc anim-3">
          Product Owner specializing in workflow automation, AI-powered pipelines,
          and eliminating every task a machine can do better — n8n, APIs, and
          zero tolerance for manual work.
        </p>

        <div class="hero-btns anim-4">
          <a href="/projects" class="btn-primary">View Projects</a>
          <a href="/articles" class="btn-ghost">Read Articles</a>
        </div>

        <div class="hero-stats anim-5">
          <div class="stat">
            <span class="stat-val">20+</span>
            <span class="stat-label">Automations Built</span>
          </div>
          <div class="stat">
            <span class="stat-val">80%</span>
            <span class="stat-label">Manual Work Cut</span>
          </div>
          <div class="stat">
            <span class="stat-val">60s</span>
            <span class="stat-label">Lead Response</span>
          </div>
        </div>
      </div>

      <!-- Right photo column -->
      <div class="hero-photo-col">
        <div class="photo-frame">
          <div class="photo-inner">
            <span class="photo-initials">TJ</span>
          </div>
        </div>
        <p class="photo-hint">Add photo to /public/images/tj-photo.jpg</p>
      </div>
    </div>
  </section>

  <!-- ══ METRICS BAR ══ -->
  <div class="metrics-bar">
    <span class="metrics-live">Live</span>
    <div class="metrics-items">
      <span class="m-item"><span class="m-key">workflows</span><span class="m-val">24 active</span></span>
      <span class="m-item"><span class="m-key">leads today</span><span class="m-val">47</span></span>
      <span class="m-item"><span class="m-key">api calls</span><span class="m-val">12.4K / week</span></span>
      <span class="m-item"><span class="m-key">hours saved</span><span class="m-val">320h</span></span>
      <span class="m-item"><span class="m-key">uptime</span><span class="m-val">99.97%</span></span>
    </div>
  </div>

  <!-- ══ ABOUT ══ -->
  <section class="section-about">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">// about</span>
        <h2 class="section-title">Who I am</h2>
      </div>
      <div class="about-grid">
        <div class="about-text">
          <p>Product Owner at an iGaming platform in Malaysia. I don't manage backlogs — I eliminate entire categories of work by automating them out of existence.</p>
          <p>My tools of choice are n8n, MySQL, and a growing stack of APIs. I care about solutions that are practical, cost-effective, and actually get used.</p>
        </div>
        <div class="about-skills">
          {[
            { name: 'n8n / Automation', pct: 92 },
            { name: 'API Integration', pct: 88 },
            { name: 'MySQL / Database', pct: 82 },
            { name: 'WhatsApp + Telegram', pct: 78 },
            { name: 'SEO Automation', pct: 72 },
            { name: 'Notion Systems', pct: 90 },
          ].map(skill => (
            <div class="skill-row">
              <div class="skill-label-row">
                <span class="skill-name">{skill.name}</span>
                <span class="skill-pct">{skill.pct}%</span>
              </div>
              <div class="skill-track">
                <div class="skill-fill" style={`width: ${skill.pct}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ PROJECTS ══ -->
  <section class="section-projects">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">// selected work</span>
        <h2 class="section-title">Systems built</h2>
      </div>

      <div class="projects-grid">
        {featuredProjects.length > 0 ? featuredProjects.map((project, i) => (
          <div class:list={['proj-card', { 'proj-featured': i < 2 }]}>
            {i < 2 && <div class="proj-top-bar" aria-hidden="true"></div>}
            <div class="proj-blob" aria-hidden="true"></div>
            <span class="proj-tag">{project.data.category}</span>
            <h3 class="proj-title">{project.data.title}</h3>
            <p class="proj-desc">{project.data.description}</p>
            <div class="proj-stack">
              {project.data.tags.slice(0, 4).map((tag: string) => (
                <span class="stack-pill">{tag}</span>
              ))}
            </div>
            {project.data.metrics && project.data.metrics.length > 0 && (
              <span class="result-badge">✓ {project.data.metrics[0].value} {project.data.metrics[0].label}</span>
            )}
          </div>
        )) : (
          <>
            {[
              { tag: 'Automation', title: 'Lead management & multi-channel notification system', desc: 'Zero-touch pipeline from form submission to WhatsApp, Telegram, and Email in under 60 seconds.', stack: ['n8n', 'MySQL', 'WhatsApp API', 'Notion'], result: '↓ 80% reduction in manual effort', featured: true },
              { tag: 'SEO × AI', title: 'SEO keyword research automation pipeline', desc: 'Scrapes Google Autocomplete + Reddit → Gemini generates full articles. Complete in under 5 minutes.', stack: ['n8n', 'Gemini API', 'Google Sheets'], result: '↓ Full article pipeline in < 5 min', featured: true },
              { tag: 'Platform', title: 'Telegram bot promotion system', desc: 'Automated weekly bonus campaigns with smart rate limiting for iGaming members.', stack: ['Telegram API', 'Node.js', 'MySQL'], result: null, featured: false },
              { tag: 'Tracking', title: 'Wealth management tracker in Notion', desc: 'Portfolio dashboard with live charts and automated data sync via n8n workflows.', stack: ['Notion API', 'n8n', 'Charts'], result: null, featured: false },
            ].map((p, i) => (
              <div class:list={['proj-card', { 'proj-featured': p.featured }]}>
                {p.featured && <div class="proj-top-bar" aria-hidden="true"></div>}
                <div class="proj-blob" aria-hidden="true"></div>
                <span class="proj-tag">{p.tag}</span>
                <h3 class="proj-title">{p.title}</h3>
                <p class="proj-desc">{p.desc}</p>
                <div class="proj-stack">
                  {p.stack.map((t: string) => <span class="stack-pill">{t}</span>)}
                </div>
                {p.result && <span class="result-badge">{p.result}</span>}
              </div>
            ))}
          </>
        )}
      </div>

      <div class="section-cta">
        <a href="/projects" class="btn-ghost">All projects →</a>
      </div>
    </div>
  </section>

  <!-- ══ ARTICLES ══ -->
  <section class="section-articles">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">// writing</span>
        <h2 class="section-title">Latest articles</h2>
      </div>

      <div class="article-list">
        {latestArticles.length > 0 ? latestArticles.map((article, i) => {
          const date = new Date(article.data.publishedDate).toLocaleDateString('en-MY', { year: 'numeric', month: 'short', day: 'numeric' });
          return (
            <a href={`/articles/${article.slug}`} class="art-row">
              <div class="art-row-left">
                <span class="art-num">0{i + 1}</span>
                <span class="art-title-text">{article.data.title}</span>
              </div>
              <div class="art-row-right">
                <span class="art-cat-badge">{article.data.category}</span>
                <time class="art-date" datetime={article.data.publishedDate}>{date}</time>
              </div>
            </a>
          );
        }) : (
          [
            { num: '01', title: 'Building a lead automation pipeline with n8n', cat: 'Automation', date: 'Mar 2025' },
            { num: '02', title: 'n8n vs Zapier: which one actually saves time?', cat: 'Tools', date: 'Feb 2025' },
            { num: '03', title: 'Notion API automation guide for product owners', cat: 'Productivity', date: 'Jan 2025' },
          ].map(a => (
            <div class="art-row">
              <div class="art-row-left">
                <span class="art-num">{a.num}</span>
                <span class="art-title-text">{a.title}</span>
              </div>
              <div class="art-row-right">
                <span class="art-cat-badge">{a.cat}</span>
                <time class="art-date">{a.date}</time>
              </div>
            </div>
          ))
        )}
      </div>

      <div class="section-cta">
        <a href="/articles" class="btn-ghost">All articles →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--white);
    border-bottom: 1px solid var(--border);
  }

  .hero-blob-tr {
    position: absolute;
    pointer-events: none;
    width: 420px; height: 420px;
    border-radius: 50%;
    background: radial-gradient(circle, #dbeafe 0%, #eff6ff 50%, transparent 70%);
    top: -120px; right: -80px;
  }
  .hero-blob-bl {
    position: absolute;
    pointer-events: none;
    width: 300px; height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, #eff6ff 0%, transparent 70%);
    bottom: -80px; left: -60px;
  }
  .hero-dots {
    position: absolute;
    pointer-events: none;
    inset: 0;
    background-image: radial-gradient(circle, #bfdbfe 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0.4;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 220px;
    position: relative;
    z-index: 1;
    padding-top: 64px;
    padding-bottom: 56px;
  }

  .hero-left {
    padding-right: 32px;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--blue-600);
    background: var(--blue-50);
    border: 1px solid var(--blue-200);
    padding: 5px 12px;
    border-radius: 20px;
    margin-bottom: 20px;
  }
  .badge-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #06b6d4;
    flex-shrink: 0;
  }

  /* H1 */
  .hero-h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 20px;
  }
  .h1-plain { color: var(--ink); }
  .h1-gradient {
    background: linear-gradient(135deg, #2563eb 0%, #6366f1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    font-size: 14px;
    color: var(--ink-3);
    line-height: 1.8;
    max-width: 440px;
    margin-bottom: 32px;
  }

  /* Buttons */
  .hero-btns {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 0;
  }
  .btn-primary {
    font-size: 13px;
    font-weight: 600;
    padding: 10px 22px;
    background: var(--blue-600);
    color: #fff;
    border-radius: var(--radius);
    transition: background 0.15s, transform 0.15s;
    display: inline-block;
  }
  .btn-primary:hover {
    background: var(--blue-700);
    transform: translateY(-1px);
  }
  .btn-ghost {
    font-size: 13px;
    font-weight: 500;
    padding: 10px 22px;
    border: 1.5px solid var(--border);
    color: var(--ink-2);
    border-radius: var(--radius);
    transition: border-color 0.15s, background 0.15s;
    display: inline-block;
  }
  .btn-ghost:hover {
    border-color: var(--blue-200);
    background: var(--blue-50);
  }

  /* Stats */
  .hero-stats {
    display: flex;
    gap: 36px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    margin-top: 44px;
  }
  .stat-val {
    display: block;
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: var(--blue-600);
  }
  .stat-label {
    display: block;
    font-size: 11px;
    font-weight: 500;
    color: var(--ink-4);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-top: 2px;
  }

  /* Photo column */
  .hero-photo-col {
    border-left: 1px solid var(--border);
    background: linear-gradient(180deg, var(--blue-50) 0%, var(--white) 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 24px;
  }
  .photo-frame {
    width: 110px; height: 110px;
    border-radius: 50%;
    border: 2px solid var(--blue-200);
    background: var(--white);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .photo-frame::before {
    content: '';
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    border: 1px dashed var(--blue-200);
  }
  .photo-inner {
    width: 90px; height: 90px;
    border-radius: 50%;
    background: var(--blue-50);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .photo-initials {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: var(--blue-600);
  }
  .photo-hint {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-4);
    text-align: center;
    line-height: 1.4;
  }

  /* ── Metrics Bar ── */
  .metrics-bar {
    background: var(--blue-600);
    padding: 10px 32px;
    display: flex;
    align-items: center;
    gap: 0;
    overflow: hidden;
  }
  .metrics-live {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-right: 28px;
    flex-shrink: 0;
  }
  .metrics-items {
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
  }
  .m-item {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .m-key {
    font-family: var(--font-mono);
    font-size: 10px;
    color: rgba(255,255,255,0.55);
  }
  .m-val {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    color: #fff;
  }

  /* ── Section commons ── */
  .section-header {
    margin-bottom: 28px;
  }
  .eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--blue-500);
    margin-bottom: 6px;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .section-cta {
    margin-top: 24px;
  }

  /* ── About ── */
  .section-about {
    padding: 48px 0;
    border-bottom: 1px solid var(--border);
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .about-text p {
    font-size: 13.5px;
    color: var(--ink-3);
    line-height: 1.85;
    margin-bottom: 16px;
  }
  .about-text p:last-child { margin-bottom: 0; }

  .skill-row { margin-bottom: 14px; }
  .skill-label-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 6px;
  }
  .skill-name { font-size: 12px; font-weight: 500; color: var(--ink-2); }
  .skill-pct { font-family: var(--font-mono); font-size: 11px; color: var(--blue-500); }
  .skill-track {
    height: 4px;
    background: var(--blue-100);
    border-radius: 4px;
    overflow: hidden;
  }
  .skill-fill {
    height: 4px;
    border-radius: 4px;
    background: linear-gradient(90deg, var(--blue-500), #6366f1);
    animation: growBar 1s 0.4s cubic-bezier(0.4, 0, 0.2, 1) both;
  }

  /* ── Projects ── */
  .section-projects {
    background: var(--bg);
    padding: 48px 0;
    border-bottom: 1px solid var(--border);
  }
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }
  .proj-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 20px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
  }
  .proj-card:hover {
    border-color: var(--blue-200);
    transform: translateY(-2px);
  }
  .proj-featured {
    border-color: var(--blue-200);
  }
  .proj-top-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--blue-500), #6366f1);
  }
  .proj-blob {
    position: absolute;
    top: -40px; right: -40px;
    width: 120px; height: 120px;
    border-radius: 50%;
    background: var(--blue-50);
    pointer-events: none;
  }
  .proj-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--blue-600);
    background: var(--blue-50);
    border: 1px solid var(--blue-200);
    padding: 3px 9px;
    border-radius: 4px;
    display: inline-block;
    margin-bottom: 10px;
  }
  .proj-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.45;
    margin-bottom: 5px;
  }
  .proj-desc {
    font-size: 12px;
    color: var(--ink-3);
    line-height: 1.65;
    margin-bottom: 12px;
  }
  .proj-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }
  .stack-pill {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 2px 8px;
    border-radius: 20px;
  }
  .result-badge {
    display: inline-block;
    margin-top: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--green);
    background: var(--green-bg);
    border: 1px solid var(--green-border);
    padding: 3px 9px;
    border-radius: 4px;
  }

  /* ── Articles ── */
  .section-articles {
    padding: 48px 0;
    border-bottom: 1px solid var(--border);
  }
  .article-list {
    display: flex;
    flex-direction: column;
  }
  .art-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
    transition: opacity 0.15s;
    gap: 16px;
  }
  .art-row:hover { opacity: 0.75; }
  .art-row:first-child { border-top: 1px solid var(--border); }
  .art-row-left {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .art-num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-4);
    width: 20px;
    flex-shrink: 0;
  }
  .art-title-text {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
  }
  .art-row-right {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }
  .art-cat-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--blue-700);
    background: var(--blue-50);
    padding: 3px 9px;
    border-radius: 4px;
  }
  .art-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-4);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-photo-col {
      display: none;
    }
    .hero-left {
      padding-right: 0;
    }
    .about-grid {
      grid-template-columns: 1fr;
    }
    .projects-grid {
      grid-template-columns: 1fr;
    }
    .art-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
    .art-row-right {
      padding-left: 34px;
    }
    .metrics-bar {
      padding: 10px 16px;
    }
    .metrics-items {
      gap: 16px;
    }
  }
</style>
