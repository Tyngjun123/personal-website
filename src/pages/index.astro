---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../config/site';
import ArticleThumbnailIcon from '../components/ArticleThumbnailIcon.astro';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 4);

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const latestArticles = allArticles
  .sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime())
  .slice(0, 4);
---

<BaseLayout title={SITE.title} description={SITE.description}>

  <!-- ══ HERO ══ -->
  <section class="hero">
    <div class="hero-blob-tr" aria-hidden="true"></div>
    <div class="hero-blob-bl" aria-hidden="true"></div>
    <div class="hero-dots" aria-hidden="true"></div>

    <div class="container hero-inner">
      <div class="hero-left">
        <div class="hero-badge anim-1">
          <span class="badge-dot"></span>
          {SITE.authorRole} · {SITE.location}
        </div>

        <h1 class="hero-h1 anim-2">
          <span class="h1-plain">Hi, I'm {SITE.author}.</span><br />
          <span class="h1-gradient">I build systems</span><br />
          <span class="h1-plain">that think.</span>
        </h1>

        <p class="hero-desc anim-3">{SITE.authorBio}</p>

        <div class="hero-btns anim-4">
          <a href="/projects" class="btn-primary">View Projects</a>
          <a href="/articles" class="btn-ghost">Read Articles</a>
        </div>

        <div class="hero-stats anim-5">
          <div class="stat">
            <span class="stat-val">20+</span>
            <span class="stat-label">Automations Built</span>
          </div>
          <div class="stat">
            <span class="stat-val">80%</span>
            <span class="stat-label">Manual Work Cut</span>
          </div>
          <div class="stat">
            <span class="stat-val">60s</span>
            <span class="stat-label">Lead Response</span>
          </div>
        </div>
      </div>

      <div class="hero-photo-col">
        <div class="photo-frame">
          <div class="photo-inner">
            <img src="/tj-photo.png" alt={SITE.author} style="border-radius: 50%; width: 100%; height: 100%; object-fit: cover;" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ METRICS BAR ══ -->
  <div class="metrics-bar">
    <span class="metrics-live">Live</span>
    <div class="metrics-items">
      <span class="m-item"><span class="m-key">workflows</span><span class="m-val">24 active</span></span>
      <span class="m-item"><span class="m-key">leads today</span><span class="m-val">47</span></span>
      <span class="m-item"><span class="m-key">api calls</span><span class="m-val">12.4K / week</span></span>
      <span class="m-item"><span class="m-key">hours saved</span><span class="m-val">320h</span></span>
      <span class="m-item"><span class="m-key">uptime</span><span class="m-val">99.97%</span></span>
    </div>
  </div>

  <!-- ══ SKILLS ══ -->
  <section class="section-skills">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">// skills</span>
        <h2 class="section-title">What I work with</h2>
      </div>
      <div class="skills-about-grid">
        <div class="about-text">
          <p>Product Owner at an iGaming platform in Malaysia. I don't manage backlogs — I eliminate entire categories of work by automating them out of existence.</p>
          <p>My tools of choice are n8n, MySQL, and a growing stack of APIs. I care about solutions that are practical, cost-effective, and actually get used.</p>
        </div>
        <div class="skills-grid">
          {[
            { name: 'n8n / Automation',    pct: 92 },
            { name: 'API Integration',     pct: 88 },
            { name: 'MySQL / Database',    pct: 82 },
            { name: 'WhatsApp + Telegram', pct: 78 },
            { name: 'SEO Automation',      pct: 72 },
            { name: 'Notion Systems',      pct: 90 },
          ].map(s => (
            <div class="skill-row">
              <div class="skill-head">
                <span class="skill-name">{s.name}</span>
                <span class="skill-pct">{s.pct}%</span>
              </div>
              <div class="skill-track">
                <div class="skill-fill" style={`width: ${s.pct}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ PROJECTS ══ -->
  <section class="section-projects">
    <div class="container">
      <div class="section-header section-header--row">
        <div>
          <span class="eyebrow">// selected work</span>
          <h2 class="section-title">Systems built</h2>
        </div>
        <a href="/projects" class="section-link">All projects →</a>
      </div>

      <div class="projects-grid">
        {featuredProjects.length > 0 ? featuredProjects.map((project, i) => (
          <div class:list={['proj-card', { 'proj-featured': i < 2 }]}>
            {i < 2 && <div class="proj-top-bar" aria-hidden="true"></div>}
            <div class="proj-blob" aria-hidden="true"></div>
            <span class="proj-tag">{project.data.category}</span>
            <h3 class="proj-title">{project.data.title}</h3>
            <p class="proj-desc">{project.data.description}</p>
            <div class="proj-stack">
              {project.data.tags.slice(0, 4).map((tag: string) => (
                <span class="stack-pill">{tag}</span>
              ))}
            </div>
            {project.data.metrics && project.data.metrics.length > 0 && (
              <span class="result-badge">✓ {project.data.metrics[0].value} {project.data.metrics[0].label}</span>
            )}
          </div>
        )) : (
          <>
            {[
              { tag: 'Automation', title: 'Lead management & multi-channel notification system', desc: 'Zero-touch pipeline from form submission to WhatsApp, Telegram, and Email in under 60 seconds.', stack: ['n8n', 'MySQL', 'WhatsApp API', 'Notion'], result: '↓ 80% reduction in manual effort', featured: true },
              { tag: 'SEO × AI',   title: 'SEO keyword research automation pipeline',           desc: 'Scrapes Google Autocomplete + Reddit → Gemini generates full articles in under 5 minutes.', stack: ['n8n', 'Gemini API', 'Google Sheets'], result: '↓ Full article pipeline in < 5 min', featured: true },
              { tag: 'Platform',  title: 'Telegram bot promotion system',                       desc: 'Automated weekly bonus campaigns with smart rate limiting for iGaming members.', stack: ['Telegram API', 'Node.js', 'MySQL'], result: null, featured: false },
              { tag: 'Tracking',  title: 'Wealth management tracker in Notion',                 desc: 'Portfolio dashboard with live charts and automated data sync via n8n workflows.', stack: ['Notion API', 'n8n', 'Charts'], result: null, featured: false },
            ].map((p, i) => (
              <div class:list={['proj-card', { 'proj-featured': p.featured }]}>
                {p.featured && <div class="proj-top-bar" aria-hidden="true"></div>}
                <div class="proj-blob" aria-hidden="true"></div>
                <span class="proj-tag">{p.tag}</span>
                <h3 class="proj-title">{p.title}</h3>
                <p class="proj-desc">{p.desc}</p>
                <div class="proj-stack">
                  {p.stack.map((t: string) => <span class="stack-pill">{t}</span>)}
                </div>
                {p.result && <span class="result-badge">{p.result}</span>}
              </div>
            ))}
          </>
        )}
      </div>
    </div>
  </section>

  <!-- ══ ARTICLES — CARD GRID ══ -->
  <section class="section-articles">
    <div class="container">
      <div class="section-header section-header--row">
        <div>
          <span class="eyebrow">// writing</span>
          <h2 class="section-title">Latest articles</h2>
        </div>
        <a href="/articles" class="section-link">View all →</a>
      </div>

      <div class="articles-card-grid">
        {latestArticles.length > 0 ? latestArticles.map(article => (
          <a href={`/articles/${article.slug}`} class="article-card">
            <div class={`article-card-img article-card-img--${article.data.category.toLowerCase().replace(/\s+/g, '-')}`}>
              {article.data.cover
                ? <img src={article.data.cover} alt={article.data.title} loading="lazy" />
                : <ArticleThumbnailIcon category={article.data.category} />
              }
              {article.data.featured && <div class="article-card-top-bar"></div>}
            </div>
            <div class="article-card-body">
              <span class={`article-cat-badge article-cat-badge--${article.data.category.toLowerCase().replace(/\s+/g, '-')}`}>
                {article.data.category}
              </span>
              <h3 class="article-card-title">{article.data.title}</h3>
              <p class="article-card-excerpt">{article.data.description}</p>
              <div class="article-card-footer">
                <time class="article-card-date">{new Date(article.data.publishedDate).toLocaleDateString('en-MY', { month: 'short', year: 'numeric' })}</time>
                {article.data.readTime && <span class="article-card-read">{article.data.readTime} read</span>}
              </div>
            </div>
          </a>
        )) : (
          [
            { slug: '#', category: 'Automation', title: 'Building a lead automation pipeline with n8n', description: 'A complete walkthrough of building a zero-touch lead pipeline.', publishedDate: '2025-03-01', readTime: '8 min', featured: true },
            { slug: '#', category: 'Tools',       title: 'n8n vs Zapier: which one actually saves time?', description: 'A real comparison from someone who uses both in production.',       publishedDate: '2025-02-01', readTime: '6 min', featured: false },
            { slug: '#', category: 'Productivity', title: 'Notion API automation guide for product owners', description: 'How to automate your Notion workspace with the API.',              publishedDate: '2025-01-01', readTime: '5 min', featured: false },
          ].map(article => (
            <a href={`/articles/${article.slug}`} class="article-card">
              <div class={`article-card-img article-card-img--${article.category.toLowerCase().replace(/\s+/g, '-')}`}>
                <ArticleThumbnailIcon category={article.category} />
                {article.featured && <div class="article-card-top-bar"></div>}
              </div>
              <div class="article-card-body">
                <span class={`article-cat-badge article-cat-badge--${article.category.toLowerCase().replace(/\s+/g, '-')}`}>
                  {article.category}
                </span>
                <h3 class="article-card-title">{article.title}</h3>
                <p class="article-card-excerpt">{article.description}</p>
                <div class="article-card-footer">
                  <time class="article-card-date">{new Date(article.publishedDate).toLocaleDateString('en-MY', { month: 'short', year: 'numeric' })}</time>
                  <span class="article-card-read">{article.readTime} read</span>
                </div>
              </div>
            </a>
          ))
        )}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--white);
    border-bottom: 1px solid var(--border);
  }
  .hero-blob-tr {
    position: absolute; pointer-events: none;
    width: 420px; height: 420px; border-radius: 50%;
    background: radial-gradient(circle, #dbeafe 0%, #eff6ff 50%, transparent 70%);
    top: -120px; right: -80px;
  }
  .hero-blob-bl {
    position: absolute; pointer-events: none;
    width: 300px; height: 300px; border-radius: 50%;
    background: radial-gradient(circle, #eff6ff 0%, transparent 70%);
    bottom: -80px; left: -60px;
  }
  .hero-dots {
    position: absolute; pointer-events: none; inset: 0;
    background-image: radial-gradient(circle, #bfdbfe 1px, transparent 1px);
    background-size: 32px 32px; opacity: 0.4;
  }
  .hero-inner {
    display: grid; grid-template-columns: 1fr 220px;
    position: relative; z-index: 1;
    padding-top: 64px; padding-bottom: 56px;
  }
  .hero-left { padding-right: 32px; }

  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--font-mono); font-size: 11px; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--blue-600); background: var(--blue-50);
    border: 1px solid var(--blue-200); padding: 5px 12px;
    border-radius: 20px; margin-bottom: 20px;
  }
  .badge-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #06b6d4; flex-shrink: 0;
  }

  .hero-h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: 700; line-height: 1.05; letter-spacing: -0.03em;
    color: var(--ink); margin-bottom: 20px;
  }
  .h1-plain { color: var(--ink); }
  .h1-gradient {
    background: var(--gradient-text);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc { font-size: 14px; color: var(--ink-3); line-height: 1.8; max-width: 440px; margin-bottom: 32px; }

  .hero-btns { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn-primary {
    font-size: 13px; font-weight: 600; padding: 10px 22px;
    background: var(--blue-600); color: #fff; border-radius: var(--radius);
    transition: background 0.15s, transform 0.15s; display: inline-block;
  }
  .btn-primary:hover { background: var(--blue-700); transform: translateY(-1px); }
  .btn-ghost {
    font-size: 13px; font-weight: 500; padding: 10px 22px;
    border: 1.5px solid var(--border); color: var(--ink-2);
    border-radius: var(--radius); transition: border-color 0.15s, background 0.15s;
    display: inline-block;
  }
  .btn-ghost:hover { border-color: var(--blue-200); background: var(--blue-50); }

  .hero-stats { display: flex; gap: 36px; padding-top: 24px; border-top: 1px solid var(--border); margin-top: 44px; }
  .stat-val { display: block; font-family: var(--font-display); font-size: 28px; font-weight: 700; color: var(--blue-600); }
  .stat-label { display: block; font-size: 11px; font-weight: 500; color: var(--ink-4); text-transform: uppercase; letter-spacing: 0.04em; margin-top: 2px; }

  .hero-photo-col {
    border-left: 1px solid var(--border);
    background: linear-gradient(180deg, var(--blue-50) 0%, var(--white) 100%);
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; padding: 24px;
  }
  .photo-frame {
    width: 110px; height: 110px; border-radius: 50%;
    border: 2px solid var(--blue-200); background: var(--white);
    position: relative; display: flex; align-items: center; justify-content: center;
  }
  .photo-frame::before {
    content: ''; position: absolute; inset: -10px; border-radius: 50%;
    border: 1px dashed var(--blue-200);
  }
  .photo-inner { width: 90px; height: 90px; border-radius: 50%; background: var(--blue-50); display: flex; align-items: center; justify-content: center; }
  .photo-initials { font-family: var(--font-display); font-size: 28px; font-weight: 700; color: var(--blue-600); }
  .photo-hint { font-family: var(--font-mono); font-size: 11px; color: var(--ink-4); text-align: center; line-height: 1.4; }

  /* ── Metrics Bar ── */
  .metrics-bar {
    background: var(--blue-600); padding: 10px 32px;
    display: flex; align-items: center; overflow: hidden;
  }
  .metrics-live { font-family: var(--font-mono); font-size: 10px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-right: 28px; flex-shrink: 0; }
  .metrics-items { display: flex; gap: 32px; flex-wrap: wrap; }
  .m-item { display: flex; gap: 8px; align-items: center; }
  .m-key { font-family: var(--font-mono); font-size: 10px; color: rgba(255,255,255,0.55); }
  .m-val { font-family: var(--font-mono); font-size: 10px; font-weight: 500; color: #fff; }

  /* ── Section commons ── */
  .section-header { margin-bottom: 28px; }
  .section-header--row { display: flex; justify-content: space-between; align-items: flex-end; }
  .eyebrow {
    display: block; font-family: var(--font-mono); font-size: 10px; font-weight: 500;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--blue-500); margin-bottom: 6px;
  }
  .section-title { font-family: var(--font-display); font-size: 24px; font-weight: 700; letter-spacing: -0.02em; color: var(--ink); }
  .section-link { font-size: 13px; font-weight: 500; color: var(--blue-600); transition: color 0.15s; }
  .section-link:hover { color: var(--blue-700); }

  /* ── Skills ── */
  .section-skills { background: var(--white); padding: 48px 0; border-bottom: 1px solid var(--border); }
  .skills-about-grid {
    display: grid; grid-template-columns: 1fr; gap: 24px;
  }
  @media (min-width: 1024px) {
    .skills-about-grid { grid-template-columns: 1fr 1fr; gap: 40px; }
  }
  .about-text p { font-size: 0.9rem; color: var(--ink-3); line-height: 1.85; margin-bottom: 12px; }
  .about-text p:last-child { margin-bottom: 0; }

  .skills-grid { display: grid; grid-template-columns: 1fr; gap: 12px; }
  @media (min-width: 768px) {
    .skills-grid { grid-template-columns: 1fr 1fr; gap: 10px 24px; }
  }

  .skill-row { display: flex; flex-direction: column; gap: 5px; }
  .skill-head { display: flex; justify-content: space-between; }
  .skill-name { font-size: 0.75rem; font-weight: 500; color: var(--ink-2); }
  .skill-pct  { font-family: var(--font-mono); font-size: 0.7rem; color: var(--blue-500); }
  .skill-track { height: 4px; background: var(--blue-100); border-radius: 4px; overflow: hidden; }
  .skill-fill {
    height: 4px; border-radius: 4px;
    background: var(--gradient-bar);
    animation: growBar 1s 0.5s cubic-bezier(0.4, 0, 0.2, 1) both;
  }

  /* ── Projects ── */
  .section-projects { background: var(--bg); padding: 48px 0; border-bottom: 1px solid var(--border); }
  .projects-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
  .proj-card {
    background: var(--white); border: 1px solid var(--border); border-radius: var(--radius-lg);
    padding: 20px; position: relative; overflow: hidden; transition: border-color 0.2s, transform 0.2s;
  }
  .proj-card:hover { border-color: var(--blue-200); transform: translateY(-2px); }
  .proj-featured { border-color: var(--blue-200); }
  .proj-top-bar { position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--gradient-bar); }
  .proj-blob { position: absolute; top: -40px; right: -40px; width: 120px; height: 120px; border-radius: 50%; background: var(--blue-50); pointer-events: none; }
  .proj-tag {
    font-family: var(--font-mono); font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--blue-600); background: var(--blue-50); border: 1px solid var(--blue-200);
    padding: 3px 9px; border-radius: 4px; display: inline-block; margin-bottom: 10px;
  }
  .proj-title { font-size: 13px; font-weight: 600; color: var(--ink); line-height: 1.45; margin-bottom: 5px; }
  .proj-desc { font-size: 12px; color: var(--ink-3); line-height: 1.65; margin-bottom: 12px; }
  .proj-stack { display: flex; flex-wrap: wrap; gap: 5px; }
  .stack-pill { font-family: var(--font-mono); font-size: 11px; color: var(--ink-3); background: var(--bg); border: 1px solid var(--border); padding: 2px 8px; border-radius: 20px; }
  .result-badge {
    display: inline-block; margin-top: 8px;
    font-family: var(--font-mono); font-size: 11px; font-weight: 500;
    color: var(--green); background: var(--green-bg); border: 1px solid var(--green-border);
    padding: 3px 9px; border-radius: 4px;
  }

  /* ── Articles card grid ── */
  .section-articles { background: var(--bg); padding: 48px 0; border-bottom: 1px solid var(--border); }
  .articles-card-grid { display: grid; grid-template-columns: 1fr; gap: 14px; }
  @media (min-width: 640px) {
    .articles-card-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  .article-card {
    display: block; border: 1px solid var(--border); border-radius: var(--radius-lg);
    overflow: hidden; background: var(--white); transition: border-color 0.2s, transform 0.2s; text-decoration: none;
  }
  .article-card:hover { border-color: var(--blue-200); transform: translateY(-2px); }

  .article-card-img {
    height: 140px; display: flex; align-items: center; justify-content: center;
    position: relative; border-bottom: 1px solid var(--border); overflow: hidden;
  }
  .article-card-img img { width: 100%; height: 100%; object-fit: cover; }

  /* Category background tints */
  .article-card-img--automation,
  .article-card-img--n8n        { background: var(--blue-50); }
  .article-card-img--seo        { background: #f0fdf4; }
  .article-card-img--dev,
  .article-card-img--tutorial   { background: #f5f3ff; }
  .article-card-img--tools      { background: #fffbeb; }
  .article-card-img--productivity { background: #f0fdf4; }

  .article-card-top-bar {
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: var(--gradient-bar);
  }

  .article-card-body { padding: 14px; }

  .article-cat-badge {
    font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    padding: 2px 7px; border-radius: 4px; display: inline-block; margin-bottom: 7px;
  }
  .article-cat-badge--automation,
  .article-cat-badge--n8n        { color: var(--blue-700); background: var(--blue-50); }
  .article-cat-badge--seo        { color: #065f46; background: #d1fae5; }
  .article-cat-badge--dev,
  .article-cat-badge--tutorial   { color: #5b21b6; background: #ede9fe; }
  .article-cat-badge--tools      { color: #92400e; background: #fef3c7; }
  .article-cat-badge--productivity { color: #065f46; background: #d1fae5; }

  .article-card-title { font-size: 0.875rem; font-weight: 600; line-height: 1.4; color: var(--ink); margin-bottom: 5px; }
  .article-card-excerpt {
    font-size: 0.775rem; color: var(--ink-3); line-height: 1.6; margin-bottom: 10px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .article-card-footer { display: flex; justify-content: space-between; align-items: center; }
  .article-card-date,
  .article-card-read { font-family: var(--font-mono); font-size: 0.7rem; color: var(--ink-4); }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-photo-col { display: none; }
    .hero-left { padding-right: 0; }
    .projects-grid { grid-template-columns: 1fr; }
    .metrics-bar { padding: 10px 16px; }
    .metrics-items { gap: 16px; }
    .section-header--row { flex-direction: column; align-items: flex-start; gap: 8px; }
  }
</style>
