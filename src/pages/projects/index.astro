---
// src/pages/projects/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="Projects" description="Automation systems, internal tools, and workflow projects.">
  <div class="page-hero">
    <div class="container">
      <span class="eyebrow">// selected work</span>
      <h1 class="page-title">Projects</h1>
      <p class="page-sub">Automation systems, internal tools, and workflow projects.</p>
    </div>
  </div>

  <section class="container page-body">
    {projects.length === 0 ? (
      <p class="empty">No projects yet — check back soon.</p>
    ) : (
      <ul class="project-grid">
        {projects.map((project, i) => (
          <li class:list={['project-card', { 'proj-featured': i < 2 }]}>
            {i < 2 && <div class="proj-top-bar" aria-hidden="true"></div>}
            <div class="proj-blob" aria-hidden="true"></div>

            <div class="project-top">
              <span class="project-cat">{project.data.category}</span>
              <span class:list={['project-status', project.data.status === 'Live' ? 'status-live' : 'status-other']}>
                {project.data.status}
              </span>
            </div>

            <h2 class="project-title">{project.data.title}</h2>
            <p class="project-desc">{project.data.description}</p>

            {project.data.metrics && project.data.metrics.length > 0 && (
              <div class="project-metrics">
                {project.data.metrics.map((m: { value: string; label: string }) => (
                  <div class="metric">
                    <span class="metric-value">{m.value}</span>
                    <span class="metric-label">{m.label}</span>
                  </div>
                ))}
              </div>
            )}

            <div class="project-tags">
              {project.data.tags.slice(0, 4).map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>

            {(project.data.links?.github || project.data.links?.demo) && (
              <div class="project-links">
                {project.data.links.github && (
                  <a href={project.data.links.github} target="_blank" rel="noopener noreferrer" class="project-link">GitHub →</a>
                )}
                {project.data.links.demo && (
                  <a href={project.data.links.demo} target="_blank" rel="noopener noreferrer" class="project-link">Live demo →</a>
                )}
              </div>
            )}
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  /* Page hero header */
  .page-hero {
    background: linear-gradient(180deg, var(--bg) 0%, var(--white) 100%);
    border-bottom: 1px solid var(--border);
    padding: 48px 0 40px;
  }
  .eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--blue-500);
    margin-bottom: 8px;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .page-sub {
    font-size: 14px;
    color: var(--ink-3);
  }

  .page-body {
    padding: 40px 2rem 5rem;
  }

  .empty {
    font-size: 14px;
    color: var(--ink-4);
  }

  /* Grid */
  .project-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 12px;
  }

  /* Card */
  .project-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
  }
  .project-card:hover {
    border-color: var(--blue-200);
    transform: translateY(-2px);
  }
  .proj-featured {
    border-color: var(--blue-200);
  }
  .proj-top-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--blue-500), #6366f1);
  }
  .proj-blob {
    position: absolute;
    top: -40px; right: -40px;
    width: 120px; height: 120px;
    border-radius: 50%;
    background: var(--blue-50);
    pointer-events: none;
  }

  .project-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .project-cat {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--blue-600);
    background: var(--blue-50);
    border: 1px solid var(--blue-200);
    padding: 3px 9px;
    border-radius: 4px;
  }

  .project-status {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    padding: 3px 9px;
    border-radius: 20px;
  }
  .status-live {
    background: var(--green-bg);
    color: var(--green);
    border: 1px solid var(--green-border);
  }
  .status-other {
    background: var(--bg);
    color: var(--ink-3);
    border: 1px solid var(--border);
  }

  .project-title {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.45;
  }

  .project-desc {
    font-size: 12px;
    color: var(--ink-3);
    line-height: 1.65;
  }

  .project-metrics {
    display: flex;
    gap: 20px;
    padding: 12px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .metric {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .metric-value {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--blue-600);
  }
  .metric-label {
    font-size: 10px;
    color: var(--ink-4);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 2px 8px;
    border-radius: 20px;
  }

  .project-links {
    display: flex;
    gap: 12px;
    margin-top: auto;
    padding-top: 4px;
  }
  .project-link {
    font-size: 12px;
    font-weight: 500;
    color: var(--blue-600);
    transition: color 0.15s;
  }
  .project-link:hover {
    color: var(--blue-700);
  }

  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
